{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_SQL_SERVER;Database=YOUR_DATABASE_NAME;User Id=YOUR_DB_USER;Password=YOUR_DB_PASSWORD;"
  },
  "CloudinarySettings": {
    "CloudName": "YOUR_CLOUDINARY_CLOUD_NAME",
    "ApiKey": "YOUR_CLOUDINARY_API_KEY",
    "ApiSecret": "YOUR_CLOUDINARY_API_SECRET"
  },
  "MercadoPago": {
    "PublicKey": "YOUR_MERCADOPAGO_PUBLIC_KEY",
    "AccessToken": "YOUR_MERCADOPAGO_ACCESS_TOKEN",
    "BackUrls": {
      "Success": "YOUR_SUCCESS_URL",
      "Failure": "YOUR_FAILURE_URL",
      "Pending": "YOUR_PENDING_URL"
    },
    "NotificationUrl": "YOUR_NOTIFICATION_URL",
    "WebhookSecret":  "YOUR_SECRET_WEBHOOK_KEY"
  },
  "GoogleKeys": {
    "ClientId": "YOUR_GOOGLE_CLIENT_ID",
    "ClientSecret": "YOUR_GOOGLE_CLIENT_SECRET"
  },
  "Resend": {
    "ApiKey": "YOUR_RESEND_API_KEY",
    "FromEmail": "noreply@tudominio.com",
    "FromName": "TiendaOnline"
  },
  "SiteUrl": "https://localhost:7256"
}