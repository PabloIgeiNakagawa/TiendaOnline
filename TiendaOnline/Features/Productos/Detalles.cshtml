@using TiendaOnline.Features.Productos
@model DetallesViewModel
@{
    ViewData["Title"] = $"Detalles - {Model.Nombre}";
}
<!-- Breadcrumb -->
<nav aria-label="breadcrumb" class="my-4">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a asp-controller="Home" asp-action="Index" class="text-decoration-none">Inicio</a>
        </li>
        <li class="breadcrumb-item">
            <a asp-action="Index" class="text-decoration-none">Productos</a>
        </li>
        @if (Model.CategoriaNombre != null)
        {
            <li class="breadcrumb-item">
                <a asp-action="Index" asp-route-CategoriaId="@Model.CategoriaId" class="text-decoration-none">@Model.CategoriaNombre</a>
            </li>
        }
        <li class="breadcrumb-item active" aria-current="page">@Model.Nombre</li>
    </ol>
</nav>

<div class="container-fluid">
    <div class="row">
        <!-- Imagen del Producto -->
        <div class="col-lg-6 col-md-6 mb-4">
            <img src="@(Model.ImagenUrl != null ? Model.ImagenUrl : Url.Content("~/img/placeholder.svg?height=500&width=500"))"
                 class="img-fluid producto-imagen-principal"
                 alt="@Model.Nombre"
                 id="imagenPrincipal" />
        </div>

        <!-- Información del Producto -->
        <div class="col-lg-6 col-md-6">
            <div>
                <!-- Categoría y stock -->
                @if (Model.CategoriaNombre != null)
                {
                    <div class="producto-categoria-detalle mb-3">
                        <span class="bg-body-secondary border fw-semibold px-2 py-1 rounded-pill small me-2">
                            <i class="bi bi-tag"></i> @Model.CategoriaNombre
                        </span>
                        @if (Model.Stock > 0 && Model.Stock <= 5)
                        {
                            <span class="badge bg-warning text-dark">Últimas unidades</span>
                        }
                        else if (Model.Stock <= 0)
                        {
                            <span class="badge bg-danger">Agotado</span>
                        }
                        else
                        {
                            <span class="badge bg-success">Disponible</span>
                        }
                    </div>
                }

                <!-- Título -->
                <h1 class="mb-3">@Model.Nombre</h1>

                <!-- Descripción -->
                <div class="mb-4">
                    <p class="lead">@Model.Descripcion</p>
                </div>

                <hr class="my-4 opacity-10">

                <!-- Precio -->
                <div class="mb-4">
                    <div>
                        <span class="fs-2 fw-bold">@Model.Precio.ToString("C", new System.Globalization.CultureInfo("es-AR"))</span>
                        <small class="fs-2">ARS</small>
                    </div>
                </div>

                <!-- Formulario para agregar al carrito -->
                @if (Model.Stock > 0)
                {
                    <form asp-controller="Carritos"  asp-action="Agregar" method="post" class="producto-acciones-detalle">

                        <input type="hidden" name="id" value="@Model.ProductoId" />

                        <div class="row g-3">
                            <div class="col-md-8">
                                <div class="d-grid gap-2 d-md-flex">
                                    <button type="submit" class="btn btn-primary btn-lg flex-fill">
                                        <i class="bi bi-cart-plus me-2"></i>Agregar al Carrito
                                    </button>
                                </div>
                            </div>
                        </div>
                    </form>
                }
                else
                {
                    <div>
                        <div class="d-grid">
                            <button class="btn btn-outline-secondary btn-lg" disabled>
                                <i class="bi bi-x-circle me-2"></i>Producto Agotado
                            </button>
                        </div>
                    </div>
                }

                <!-- Información adicional -->
                <div class="card bg-body-tertiary border-0 rounded-4 my-4">
                    <div class="card-body p-3">
                        <div class="d-flex align-items-start mb-3">
                            <i class="bi bi-truck text-primary fs-4 me-3"></i>
                            <div>
                                <h6 class="mb-0 fw-bold">Envío a todo el país</h6>
                                <p class="small text-muted mb-0">Calculá el costo en el checkout.</p>
                            </div>
                        </div>
                        <div class="d-flex align-items-start">
                            <i class="bi bi-shield-check text-primary fs-4 me-3"></i>
                            <div>
                                <h6 class="mb-0 fw-bold">Garantía de Satisfacción</h6>
                                <p class="small text-muted mb-0">30 días para devoluciones gratuitas.</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Botones de navegación -->
                <div class="my-4">
                    <a asp-action="Index" class="btn text-secondary-emphasis"><i class="bi bi-arrow-left"></i> Volver a productos</a>
                </div>
            </div>
        </div>
    </div>
</div>