@using TiendaOnline.Enums
@model TiendaOnline.Features.Pedidos.ConfirmacionPedidoViewModel

<div class="row mt-5">
    <partial name="_ProgresoCompra" model="3" />

    <partial name="_TituloSeccion" model='("Revisá tu pedido", "Por favor, verificá que toda la información sea correcta antes de finalizar")' />

    <!-- Tabla de productos -->
    <div class="col-lg-8">
        <div class="card mb-4">
            <div class="card-header py-3 bg-body-tertiary d-flex align-items-center justify-content-between">
                <h5 class="mb-0 fw-bold">RESUMEN DE PRODUCTOS</h5>
                <span class="badge rounded-pill bg-primary">@Model.Items.Count() productos</span>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 border-top-0">
                        <thead class="text-secondary small text-uppercase">
                            <tr>
                                <th class="ps-4 border-0 py-3" style="letter-spacing: 0.5px;">Producto</th>
                                <th class="text-center border-0 py-3">Cantidad</th>
                                <th class="text-end pe-4 border-0 py-3">Subtotal</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Items)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center">
                                            @if (!string.IsNullOrEmpty(item.ImagenUrl))
                                            {
                                                <div class="position-relative">
                                                    <img src="@item.ImagenUrl" alt="@item.Nombre"
                                                         class="rounded border shadow-sm me-3"
                                                         style="width: 60px; height: 60px; object-fit: cover;">
                                                </div>
                                            }
                                            <div>
                                                <span class="fw-bold d-block text-body-emphasis">@item.Nombre</span>
                                                <small class="text-secondary-emphasis opacity-75">
                                                    <span class="text-muted">Unitario:</span> @item.Precio.ToString("C")
                                                </small>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge bg-body-secondary text-body border fw-medium px-3 py-2">
                                            @item.Cantidad
                                        </span>
                                    </td>

                                    <td class="text-end pe-4">
                                        <span class="fs-6 fw-bold text-primary-emphasis">
                                            @((item.Precio * item.Cantidad).ToString("C"))
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Datos de entrega -->
        <div class="card p-2 mb-4">
            <div class="card-header bg-transparent border-bottom-0 pt-3">
                <div class="d-flex justify-content-between align-items-center">
                    <h6 class="text-uppercase fw-bold ls-2 mb-0" style="letter-spacing: 1.5px;">Resumen de Entrega</h6>
                    <span class="badge rounded-pill @(Model.MetodoEntrega == MetodoEntrega.RetiroLocal ? "bg-info-subtle text-info-emphasis border border-info-subtle" : "bg-primary-subtle text-primary-emphasis border border-primary-subtle") px-3">
                        <i class="bi @(Model.MetodoEntrega == MetodoEntrega.RetiroLocal ? "bi-shop" : "bi-truck") me-1"></i>
                        @(Model.MetodoEntrega == MetodoEntrega.RetiroLocal ? "Retiro en Local" : "Envío a Domicilio")
                    </span>
                </div>
            </div>
            <div class="card-body pt-2">
                @if (Model.MetodoEntrega == MetodoEntrega.EnvioDomicilio && Model.Direccion != null)
                {
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <span class="badge bg-secondary text-uppercase" style="font-size: 0.7rem;">@Model.Direccion.Etiqueta</span>
                    </div>

                    <div class="d-flex mb-2">
                        <i class="bi bi-geo-alt text-primary me-2"></i>
                        <div>
                            <p class="mb-0 fw-semibold">@Model.Direccion.Calle @Model.Direccion.Numero</p>
                            <p class="mb-0 small text-secondary">@Model.Direccion.Localidad, @Model.Direccion.Provincia (@Model.Direccion.CodigoPostal)</p>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.Direccion.Observaciones))
                    {
                        <div class="mt-2 pt-2 border-top border-secondary-subtle">
                            <small class="text-muted d-block mb-1 font-monospace" style="font-size: 0.75rem;">OBSERVACIONES:</small>
                            <p class="mb-0 small fst-italic">"@Model.Direccion.Observaciones"</p>
                        </div>
                    }
                }
                else
                {
                    <div class="alert alert-info border-0 shadow-sm mb-0 d-flex align-items-center">
                        <i class="bi bi-info-circle-fill fs-4 me-3"></i>
                        <span>Te esperamos en nuestra sucursal, <b>@AppSettings.GetValue("Ubicacion:Direccion"), @AppSettings.GetValue("Ubicacion:Ciudad"), @AppSettings.GetValue("Ubicacion:Provincia").</b>.</span>
                    </div>
                }
            </div>
        </div>

        <!-- Datos del usuario -->
        <div class="card p-2 mb-4">
            <div class="card-header bg-transparent border-bottom-0 pt-3">
                <h6 class="text-uppercase fw-bold ls-2 mb-0" style="letter-spacing: 1px;">
                    Información del Cliente
                </h6>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-4">
                        <div class="d-flex align-items-center">
                            <div class="text-primary p-2 me-1 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                <i class="bi bi-person fs-5"></i>
                            </div>
                            <div>
                                <p class="mb-0 text-secondary small text-uppercase fw-semibold" style="font-size: 0.7rem;">Nombre Completo</p>
                                <p class="fw-bold mb-0 text-body-emphasis">@Model.NombreUsuario</p>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="d-flex align-items-center border-start-md ps-md-4">
                            <div class="text-secondary p-2 me-1 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                <i class="bi bi-envelope-at fs-5"></i>
                            </div>
                            <div>
                                <p class="mb-0 text-secondary small text-uppercase fw-semibold" style="font-size: 0.7rem;">Email</p>
                                <p class="fw-bold mb-0 text-body-emphasis">@Model.EmailUsuario</p>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="d-flex align-items-center border-start-md ps-md-4">
                            <div class="text-secondary p-2 me-1 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                <i class="bi bi-telephone fs-5"></i>
                            </div>
                            <div>
                                <p class="mb-0 text-secondary small text-uppercase fw-semibold" style="font-size: 0.7rem;">Teléfono</p>
                                <p class="fw-bold mb-0 text-body-emphasis">@Model.TelefonoUsuario</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4 mb-5">
        <div class="card">
            <div class="card-body p-4">
                <h5 class="card-title mb-4 fw-bold">Resumen de compra</h5>

                <div class="d-flex justify-content-between mb-2">
                    <span class="text-secondary">Subtotal</span>
                    <span class="fw-semibold text-body-emphasis">@Model.SubTotal.ToString("C")</span>
                </div>

                <div class="d-flex justify-content-between mb-3">
                    <span class="text-secondary">Envío</span>
                    <span class="fw-bold text-body-emphasis">
                        @(Model.CostoEnvio == 0 ? "Sin Envío" : Model.CostoEnvio.ToString("C"))
                    </span>
                </div>

                <hr class="my-4 border-secondary opacity-10">

                <div class="d-flex justify-content-between align-items-center mb-1">
                    <span class="h5 fw-bold mb-0">Total</span>
                    <div class="text-end">
                        <span class="h3 mb-0 fw-black text-primary">@((Model.SubTotal + Model.CostoEnvio).ToString("C"))</span>
                        <div class="small text-muted" style="font-size: 0.7rem;">(IVA incluido)</div>
                    </div>
                </div>

                <h6 class="card-subtitle mt-4 mb-3 text-secondary fw-bold text-uppercase" style="letter-spacing: 1px; font-size: 0.75rem;">
                    Pagás de forma segura con:
                </h6>
                <div class="d-flex flex-wrap gap-2 justify-content-center align-items-center mb-4">
                    <div class="bg-body-tertiary rounded-2 p-2 d-flex align-items-center justify-content-center" style="width: 55px; height: 40px;">
                        <img src="~/img/logos/visa_logo.svg" alt="Visa" class="img-fluid grayscale-filter">
                    </div>

                    <div class="bg-body-tertiary rounded-2 p-2 d-flex align-items-center justify-content-center" style="width: 55px; height: 40px;">
                        <img src="~/img/logos/mastercard_logo.svg" alt="MasterCard" class="img-fluid grayscale-filter">
                    </div>

                    <div class="bg-body-tertiary rounded-2 d-flex align-items-center justify-content-center" style="width: 75px; height: 40px;">
                        <img src="~/img/logos/mercado_pago_logo_horizontal.svg" alt="Mercado Pago" class="img-fluid grayscale-filter">
                    </div>

                    <div class="bg-body-tertiary rounded-2 p-2 d-flex align-items-center justify-content-center text-muted" style="width: 55px; height: 40px;">
                        <i class="bi bi-bank fs-5"></i>
                    </div>
                </div>

                <form asp-action="FinalizarCompra" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="metodoDePagoId" value="@((int)MetodoPagoId.MercadoPago)" />
                    <input type="hidden" asp-for="MetodoEntrega" />
                    @if (Model.MetodoEntrega == MetodoEntrega.EnvioDomicilio && Model.Direccion != null)
                    {
                        <input type="hidden" asp-for="Direccion.EsNueva" />
                        <input type="hidden" asp-for="Direccion.Etiqueta" />
                        <input type="hidden" asp-for="Direccion.Provincia" />
                        <input type="hidden" asp-for="Direccion.Localidad" />
                        <input type="hidden" asp-for="Direccion.CodigoPostal" />
                        <input type="hidden" asp-for="Direccion.Calle" />
                        <input type="hidden" asp-for="Direccion.Numero" />
                        <input type="hidden" asp-for="Direccion.Piso" />
                        <input type="hidden" asp-for="Direccion.Departamento" />
                        <input type="hidden" asp-for="Direccion.Observaciones" />
                    }


                    <button type="submit" class="btn btn-primary w-100 mb-3 py-2.5 fw-semibold d-flex align-items-center justify-content-center border-0">
                        <i class="bi bi-check2-circle me-2 fs-5"></i>
                        Confirmar Compra
                    </button>
                </form>

                <div class="text-center mt-3">
                    <a asp-action="CheckOut" class="text-decoration-none small text-muted hover-primary">
                        <i class="bi bi-arrow-left me-1"></i> Volver a datos de envío
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>