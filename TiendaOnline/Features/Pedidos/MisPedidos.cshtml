@using TiendaOnline.Extensions
@using TiendaOnline.Features.Pedidos
@model MisPedidosViewModel
@{
    ViewData["Title"] = "Mis Pedidos";
}

<div class="container-fluid py-4">
    <!-- Titulo -->
    <partial name="_TituloSeccion" model='("Mis pedidos", "Historial completo de tus pedidos")' />

    <!-- Lista de Pedidos -->
    <div class="row">
        <div class="col-12">
            <div style="min-height: 400px;">
                @if (Model.Pedidos.Any())
                {
                    @foreach (var pedido in Model.Pedidos)
                    {
                        <div class="card mb-4 overflow-hidden">
                            <!-- HEADER -->
                            <div class="card-header bg-body-tertiary border-bottom-0 py-3">
                                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                                    <div>
                                        <h5 class="fw-bold mb-0">Pedido <span class="text-primary">#@pedido.PedidoId</span></h5>
                                        <small class="text-secondary">@pedido.FechaPedido.ToString("D")</small>
                                    </div>
                                    <div class="d-flex gap-2">
                                        <span class="badge rounded-pill @(pedido.EstaCancelado ? "bg-danger-subtle text-danger" : "bg-primary-subtle text-primary") border border-primary-subtle px-3 py-2">
                                            @pedido.Estado.GetDisplayName()
                                        </span>
                                        <span class="badge rounded-pill bg-body-secondary text-body-emphasis border px-3 py-2">
                                            <i class="bi bi-credit-card me-1"></i> @pedido.EstadoPago.GetDisplayName()
                                        </span>
                                    </div>
                                </div>
                            </div>
                            <!-- BODY -->
                            <div class="card-body pb-0 mx-2">
                                <!-- TIMELINE -->
                                <div class="mb-4">
                                    <div class="d-flex flex-row align-items-start align-items-md-center justify-content-between">

                                        @{
                                            var pasoActual = 1;

                                            if (pedido.EstaCancelado)
                                                pasoActual = 3;
                                            else if (pedido.EstaEntregado)
                                                pasoActual = 3;
                                            else if (pedido.FechaEnvio.HasValue)
                                                pasoActual = 2;
                                        }

                                    <!-- PASO 1 -->
                                    <div class="text-center flex-fill mb-3 mb-md-0">
                                        <div class="rounded-circle mx-auto mb-2 d-flex align-items-center justify-content-center
                                                @(pasoActual > 1 ? "bg-success text-white" :
                                                pasoActual == 1 ? "bg-primary text-white" :
                                                "bg-body-secondary text-secondary")"
                                            style="width:3rem;height:3rem;">
                                            <i class="bi bi-cart-check"></i>
                                        </div>

                                        <h6 class="m-0 small fw-semibold">Pedido realizado</h6>
                                        <small class="text-muted d-block">
                                            @pedido.FechaPedido.ToString("dd/MM/yyyy HH:mm")
                                        </small>
                                    </div>
                                    <!-- Línea 1 -->
                                    <div class="flex-grow-1 border-top mx-3 d-none d-md-block @(pasoActual > 1 ? "border-success" : "border-secondary")">
                                    </div>
                                    <!-- PASO 2 -->
                                    <div class="text-center flex-fill mb-3 mb-md-0">
                                        <div class="rounded-circle mx-auto mb-2 d-flex align-items-center justify-content-center
                                                    @(pasoActual > 2 ? "bg-success text-white" :
                                                    pasoActual == 2 ? "bg-primary text-white" :
                                                    "bg-body-secondary text-secondary")"
                                         style="width:3rem;height:3rem;">
                                        <i class="bi bi-truck"></i>
                                    </div>

                                    @if (pedido.FechaEnvio.HasValue)
                                            {
                                                <h6 class="m-0 small fw-semibold">Enviado</h6>
                                                <small class="text-muted d-block">
                                                    @pedido.FechaEnvio.Value.ToString("dd/MM/yyyy HH:mm")
                                                </small>
                                            }
                                            else
                                            {
                                                <h6 class="m-0 small fw-semibold">Pendiente de envío</h6>
                                            }
                                    </div>
                                    <!-- Línea 2 -->
                                    <div class="flex-grow-1 border-top mx-3 d-none d-md-block
                                                @(pasoActual == 3 ? (pedido.EstaCancelado ? "border-danger" : "border-success") : "border-secondary")">
                                    </div>
                                    <!-- PASO 3 -->
                                    <div class="text-center flex-fill">
                                        <div class="rounded-circle mx-auto mb-2 d-flex align-items-center justify-content-center
                                                    @(pedido.EstaCancelado ? "bg-danger text-white" :
                                                    pasoActual == 3 ? "bg-success text-white" :
                                                    "bg-body-secondary text-secondary")"
                                         style="width:3rem;height:3rem;">

                                        @if (pedido.EstaCancelado)
                                                {
                                                    <i class="bi bi-x-circle"></i>
                                                }
                                                else
                                                {
                                                    <i class="bi bi-check-circle"></i>
                                                }

                                            </div>

                                            @if (pedido.EstaCancelado)
                                            {
                                                <h6 class="m-0 small fw-semibold text-danger">Cancelado</h6>
                                                <small class="text-muted d-block">
                                                    @pedido.FechaCancelado?.ToString("dd/MM/yyyy HH:mm")
                                                </small>
                                            }
                                            else if (pedido.EstaEntregado)
                                            {
                                                <h6 class="m-0 small fw-semibold text-success">Entregado</h6>
                                                <small class="text-muted d-block">
                                                    @pedido.FechaEntrega?.ToString("dd/MM/yyyy HH:mm")
                                                </small>
                                            }
                                            else
                                            {
                                                <h6 class="m-0 small fw-semibold">Pendiente de entrega</h6>
                                            }
                                        </div>

                                    </div>
                                </div>

                                <hr class="my-4 border-secondary opacity-10">

                                <!-- Productos -->
                                <div class="px-4 py-3 rounded-bottom-3">
                                    <h6 class="text-uppercase small fw-bold mb-3 text-secondary-emphasis" style="letter-spacing: 1px;">
                                        <i class="bi bi-box-seam me-2 text-primary"></i>Productos
                                    </h6>

                                    <div class="row g-2">
                                        @foreach (var producto in pedido.Productos)
                                        {
                                            <div class="col-12 col-md-auto">
                                                <div class="bg-body border border-secondary-subtle rounded-2 px-3 py-2 d-flex align-items-center h-100 shadow-sm">
                                                    <i class="bi bi-dot text-primary me-1 flex-shrink-0"></i>
                                                    <span class="small text-body-emphasis">@producto</span>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>

                                <hr class="my-4 border-secondary opacity-10">

                            </div>
                            <!-- Footer -->
                            <div class="card-footer bg-transparent border-0 d-flex justify-content-end pt-0 pb-3">
                                <a asp-action="Detalles"
                                   asp-route-id="@pedido.PedidoId"
                                   class="btn border-0 fw-bold">
                                    Ver detalles <i class="bi bi-arrow-right"></i>
                                </a>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center py-5">
                        <div class="mb-3">
                            <i class="bi bi-bag-x" style="font-size: 4rem;"></i>
                        </div>
                        <h5 class="text-muted">No tienes pedidos aún</h5>
                        <p class="text-muted">¡Explora nuestro catálogo y realiza tu primera compra!</p>
                        <a asp-action="Index" class="btn btn-primary">
                            <i class="bi bi-shop me-2"></i>Ver Productos
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>