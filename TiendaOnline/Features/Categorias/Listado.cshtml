@using TiendaOnline.Features.Categorias
@using TiendaOnline.Features.Shared.ViewModels
@model CategoriaListadoViewModel
@{
    ViewData["Title"] = "Gestión de Categorías";

    var filtrosActivos = new List<FiltroPill>();

    if (!string.IsNullOrEmpty(Model.Busqueda))
        filtrosActivos.Add(new FiltroPill { Icono = "bi-search", Etiqueta = "Categoría", Valor = Model.Busqueda, Propiedad = nameof(Model.Busqueda) });

    if (!string.IsNullOrEmpty(Model.Nivel))
        filtrosActivos.Add(new FiltroPill { Icono = "bi-diagram-3", Etiqueta = "Nivel", Valor = Model.Nivel, Propiedad = nameof(Model.Nivel) });

}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-md-flex justify-content-md-between align-items-md-center">
                <partial name="_TituloSeccion" model='("Gestión de Categorías", "Organiza la estructura de hardware y componentes")' />
                <a asp-controller="Categorias" asp-action="AgregarCategoria" class="btn btn-primary btn-lg shadow-sm mt-2 mt-md-0">
                    <i class="bi bi-plus-circle me-2"></i>
                    Nueva Categoría
                </a>
            </div>
        </div>
    </div>

    <!-- Filtros -->
    <form method="get" asp-action="Listado">
        <div class="row mb-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-1">
                                <label for="TamanoPagina" class="form-label fw-bold text-muted small">Ver</label>
                                <select name="TamanoPagina" class="form-select">
                                    @{
                                        int[] opciones = { 10, 25, 50, 75, 100 };
                                        foreach (var cantidad in opciones)
                                        {
                                            <option value="@cantidad" selected="@(Model.Paginacion.RegistrosPorPagina == cantidad ? "selected" : null)">
                                                @cantidad
                                            </option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="col-md-2">
                                <label for="Busqueda" class="form-label fw-semibold">
                                    <i class="bi bi-search me-1"></i>Buscar
                                </label>
                                <input type="text" name="Busqueda" value="@Model.Busqueda" class="form-control" placeholder="Buscar por nombre de categoría...">
                            </div>
                            <div class="col-md-2">
                                <label for="Nivel" class="form-label fw-semibold">
                                    <i class="bi bi-funnel me-1"></i>Nivel
                                </label>
                                <select name="Nivel" class="form-select">
                                    <option value="">Todos los niveles</option>
                                    <option value="Principal" selected='@(Model.Nivel == "Principal")'>Categorías Principales</option>
                                    <option value="Subcategoría" selected='@(Model.Nivel == "Subcategoría")'>Subcategorías</option>
                                </select>
                            </div>
                            <div class="col-md-2 d-flex align-items-end gap-2">
                                <button type="submit" class="btn btn-primary rounded-3 flex-fill">
                                    <i class="bi bi-filter me-1"></i>
                                </button>
                                <a asp-action="Listado" class="btn btn-outline-secondary rounded-3 flex-fill">
                                    <i class="bi bi-arrow-clockwise me-1"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>

    <partial name="_ResumenResultados" 
        model="@(new ResumenResultadosViewModel{
                    TotalRegistros = Model.Paginacion.TotalRegistros,
                    Desde = Model.Paginacion.DesdeRegistro,
                    Hasta = Model.Paginacion.HastaRegistro,
                    NombreEntidad = "categorias",
                    ActionName = "Listado",
                    Filtros = filtrosActivos
    })" />

    <!-- Tabla -->
    <div class="table-responsive">
        <table class="table table-hover mb-0" id="tablaCategorias">
            <thead>
                <tr>
                    <th class="py-3" style="width: 40%">
                        <i class="bi bi-folder2-open me-2 text-primary"></i>Jerarquía / Nombre
                    </th>
                    <th class="py-3">
                        <i class="bi bi-diagram-3 me-2 text-primary"></i>Dependencias
                    </th>
                    <th class="py-3">
                        <i class="bi bi-activity me-2 text-primary"></i>Estado
                    </th>
                    <th class="py-3 text-center">
                        <i class="bi bi-gear me-1 text-primary"></i>Acciones
                    </th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Paginacion.Items)
                {
                    bool esPrincipal = item.CategoriaPadreId == null;
                    <tr class="fila-categoria" data-nombre="@item.Nombre" data-tipo="@(esPrincipal ? "Principal" : "Subcategoría")">
                        <td class="py-3">
                            <div class="d-flex align-items-center">
                                <div class="me-3">
                                    <i class="bi @(esPrincipal ? "bi-folder-fill text-primary" : "bi-folder text-secondary")"></i>
                                </div>
                                <div>
                                    @if (!esPrincipal)
                                    {
                                        <small class="text-muted d-block mb-1">
                                            @item.CategoriaPadreNombre <i class="bi bi-chevron-right mx-1 small"></i>
                                        </small>
                                    }
                                    <div class="fw-semibold">@item.Nombre</div>
                                </div>
                            </div>
                        </td>
                        <td class="py-3">
                            <span class="text-muted small">
                                <i class="bi bi-box me-1"></i>@item.CantidadProductos Productos<br />
                                <i class="bi bi-node-plus me-1"></i>@item.CantidadSubcategorias Subcategorías
                            </span>
                        </td>
                        <td class="py-3">
                            @* Asumiendo que agregaste el bool Activa *@
                            <span class="badge @(true ? "bg-success" : "bg-secondary") px-3 py-2 rounded-pill">
                                Activa
                            </span>
                        </td>
                        <td class="py-3">
                            <div class="d-flex justify-content-center gap-1">
                                <a asp-action="Editar" asp-route-id="@item.CategoriaId"
                                   class="btn btn-outline-primary btn-sm" title="Editar">
                                    <i class="bi bi-pencil"></i>
                                </a>

                                <button type="button"
                                        class="btn btn-outline-danger btn-sm btn-eliminar-categoria"
                                        data-id="@item.CategoriaId"
                                        data-nombre="@item.Nombre"
                                        title="Eliminar"
                                        @(item.CantidadProductos == 0 || item.CantidadSubcategorias == 0 ? "disabled" : "")>
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Paginación -->
    <partial name="_Paginacion" model="@(new PaginacionViewModel { 
        PaginaActual = Model.Paginacion.PaginaActual, 
        TotalPaginas = Model.Paginacion.TotalPaginas,
        Accion = "Listado"
    })" />
</div>

<!-- Modal eliminar categoria -->
<partial name="_ModalCambiarEstado" />

<!-- Formularios Ocultos -->
<div style="display: none;">
    @foreach (var categoria in Model.Paginacion.Items)
    {
        <form id="eliminarCategoria@(categoria.CategoriaId)" asp-area="Admin" asp-controller="Categorias" asp-action="Eliminar" method="post">
            <input type="hidden" name="id" value="@categoria.CategoriaId" />
            @Html.AntiForgeryToken()
        </form>
    }
</div>

@section Scripts {
    <script src="~/js/Features/Categorias/Admin/Listado.js" asp-append-version="true"></script>
}