@using TiendaOnline.Extensions
@using TiendaOnline.Features.Reportes
@using TiendaOnline.Enums
@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}
@section Styles{
    <style>
        @@media print {
            .btn, .card-header button {
                display: none !important;
            }

            .card {
                break-inside: avoid;
            }
        }
    </style>
}
<!-- Header del Dashboard -->
<div class="row mb-4">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
            <partial name="_TituloSeccion" model='("Dashboards", $"Última actualización: {DateTime.Now.ToString("dd/MM/yyyy HH:mm")}")' />
            <div>
                <button id="btnImprimir" class="btn btn-outline-secondary">
                    <i class="bi bi-printer me-1"></i>Imprimir
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Tarjetas de Métricas Principales -->
<div class="row g-3 mb-4">
    <!-- Ventas Totales -->
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card bg-body-tertiary border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted mb-1 small">Ventas del Mes</p>
                        <h3 class="mb-0 fw-bold">@Model.MetricasGenerales.VentasMesActual.ToString("C", new System.Globalization.CultureInfo("es-CO"))</h3>
                    </div>
                    <div class="bg-success bg-opacity-10 rounded-3 p-3">
                        <i class="bi bi-cash-coin text-success fs-4"></i>
                    </div>
                </div>
                <div class="mt-3">
                    @if (Model.MetricasGenerales.PorcentajeCambioVentas >= 0)
                    {
                        <span class="badge bg-success bg-opacity-10 text-success">
                            <i class="bi bi-arrow-up"></i> @Model.MetricasGenerales.PorcentajeCambioVentas.ToString("F1")%
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-danger bg-opacity-10 text-danger">
                            <i class="bi bi-arrow-down"></i> @Math.Abs(Model.MetricasGenerales.PorcentajeCambioVentas).ToString("F1")%
                        </span>
                    }
                    <small class="text-muted ms-2">vs mes anterior</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Total Pedidos -->
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card bg-body-tertiary border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted mb-1 small">Pedidos del Mes</p>
                        <h3 class="mb-0 fw-bold">@Model.MetricasGenerales.PedidosMesActual</h3>
                    </div>
                    <div class="bg-primary bg-opacity-10 rounded-3 p-3">
                        <i class="bi bi-cart-check text-primary fs-4"></i>
                    </div>
                </div>
                <div class="mt-3">
                    @if (Model.MetricasGenerales.PorcentajeCambioPedidos >= 0)
                    {
                        <span class="badge bg-success bg-opacity-10 text-success">
                            <i class="bi bi-arrow-up"></i> @Model.MetricasGenerales.PorcentajeCambioPedidos.ToString("F1")%
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-danger bg-opacity-10 text-danger">
                            <i class="bi bi-arrow-down"></i> @Math.Abs(Model.MetricasGenerales.PorcentajeCambioPedidos).ToString("F1")%
                        </span>
                    }
                    <small class="text-muted ms-2">vs mes anterior</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Total Clientes -->
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card bg-body-tertiary border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted mb-1 small">Nuevos Clientes</p>
                        <h3 class="mb-0 fw-bold">@Model.MetricasGenerales.ClientesMesActual</h3>
                    </div>
                    <div class="bg-info bg-opacity-10 rounded-3 p-3">
                        <i class="bi bi-people text-info fs-4"></i>
                    </div>
                </div>
                <div class="mt-3">
                    @if (Model.MetricasGenerales.PorcentajeCambioClientes >= 0)
                    {
                        <span class="badge bg-success bg-opacity-10 text-success">
                            <i class="bi bi-arrow-up"></i> @Model.MetricasGenerales.PorcentajeCambioClientes.ToString("F1")%
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-danger bg-opacity-10 text-danger">
                            <i class="bi bi-arrow-down"></i> @Math.Abs(Model.MetricasGenerales.PorcentajeCambioClientes).ToString("F1")%
                        </span>
                    }
                    <small class="text-muted ms-2">vs mes anterior</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Ticket Promedio -->
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card bg-body-tertiary border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted mb-1 small">Ticket Promedio</p>
                        <h3 class="mb-0 fw-bold">@Model.MetricasGenerales.PromedioVentaPorPedido.ToString("C", new System.Globalization.CultureInfo("es-CO"))</h3>
                    </div>
                    <div class="bg-success bg-opacity-10 rounded-3 p-3">
                        <i class="bi bi-receipt text-success fs-4"></i>
                    </div>
                </div>
                <div class="mt-3">
                    <small class="text-muted">Promedio por compra</small>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Métricas Secundarias -->
<div class="row g-3 mb-4">
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card bg-body-tertiary border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted mb-1 small">Tiempo Promedio de Preparación</p>
                        @if (Model.MetricasGenerales.TiempoPromedioPreparacionHoras > 0)
                        {
                            var horas = (int)Model.MetricasGenerales.TiempoPromedioPreparacionHoras;
                            var minutos = (int)((Model.MetricasGenerales.TiempoPromedioPreparacionHoras - horas) * 60);
                            <h3 class="mb-0 fw-bold">@horas<span class="fs-5">h</span> @minutos<span class="fs-5">m</span></h3>
                            <small class="text-muted">De "En preparación" a "Enviado"</small>
                        }
                        else
                        {
                            <h3 class="mb-0 fw-bold text-muted">--</h3>
                            <small class="text-muted">Sin datos suficientes</small>
                        }
                    </div>
                    <div class="bg-warning bg-opacity-10 rounded-3 p-3">
                        <i class="bi bi-clock-history text-warning fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Gráficos Principales -->
<div class="row g-3 mb-4">
    <!-- Gráfico de Ventas por Mes -->
    <div class="col-12 col-lg-8">
        <div class="card bg-body-tertiary border-0 shadow-sm h-100">
            <div class="card-header bg-transparent border-0 pt-4 pb-0">
                <h5 class="mb-0 fw-semibold">
                    <i class="bi bi-graph-up text-primary me-2"></i>
                    Ventas de los Últimos 12 Meses
                </h5>
            </div>
            <div class="card-body">
                <canvas id="graficoVentasMensuales" style="max-height: 300px;"></canvas>
                <script type="application/json" id="datosVentas">
                    @Html.Raw(Json.Serialize(Model.VentasPorMes))
                </script>
            </div>
        </div>
    </div>

    <!-- Gráfico de Estados de Pedidos -->
    <div class="col-12 col-lg-4">
        <div class="card bg-body-tertiary border-0 shadow-sm h-100">
            <div class="card-header bg-transparent border-0 pt-4 pb-0">
                <h5 class="mb-0 fw-semibold">
                    <i class="bi bi-pie-chart text-primary me-2"></i>
                    Estado de Pedidos
                </h5>
            </div>
            <div class="card-body d-flex align-items-center justify-content-center">
                <canvas id="graficoEstadosPedidos" style="max-height: 250px;"></canvas>
                <script type="application/json" id="datosEstados">
                    @Html.Raw(Json.Serialize(Model.EstadisticasPedidos))
                </script>
            </div>
        </div>
    </div>
</div>

<!-- Ventas por Categoría, Top Productos y Método de Pago -->
<div class="row g-3 mb-4">
    <!-- Ventas por Categoría -->
    <div class="col-12 col-lg-6">
        <div class="card bg-body-tertiary border-0 shadow-sm h-100">
            <div class="card-header bg-transparent border-0 pt-4 pb-3">
                <h5 class="mb-0 fw-semibold">
                    <i class="bi bi-tag text-primary me-2"></i>
                    Ventas por Categoría
                </h5>
            </div>
            <div class="card-body">
                @if (Model.VentasPorCategoria.Any())
                {
                    @foreach (var categoria in Model.VentasPorCategoria.Take(5))
                    {
                        <div class="mb-3">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <span class="fw-medium">@categoria.Categoria</span>
                                <span class="text-muted small">@categoria.TotalVentas.ToString("C", new System.Globalization.CultureInfo("es-CO"))</span>
                            </div>
                            <div class="progress" style="height: 8px;">
                                <div class="progress-bar bg-primary" role="progressbar" style="width: @categoria.PorcentajeDelTotal%"></div>
                            </div>
                            <small class="text-muted">@categoria.CantidadProductos productos vendidos (@categoria.PorcentajeDelTotal%)</small>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted text-center py-4">No hay datos disponibles</p>
                }
            </div>
        </div>
    </div>

    <!-- Ventas por Método de Pago -->
    <div class="col-12 col-lg-6">
        <div class="card bg-body-tertiary border-0 shadow-sm h-100">
            <div class="card-header bg-transparent border-0 pt-4 pb-3">
                <h5 class="mb-0 fw-semibold">
                    <i class="bi bi-credit-card text-primary me-2"></i>
                    Ventas por Método de Pago
                </h5>
            </div>
            <div class="card-body">
                @if (Model.VentasPorMetodoDePago.Any())
                {
                    <canvas id="graficoMetodoPago" style="max-height: 200px;" class="mb-3"></canvas>
                    <script type="application/json" id="datosMetodoPago">
                        @Html.Raw(Json.Serialize(Model.VentasPorMetodoDePago))
                    </script>
                    <div class="table-responsive bg-transparent">
                        <table class="table table-hover align-middle">
                            <thead>
                                <tr>
                                    <th class="bg-transparent text-muted small uppercase">Método</th>
                                    <th class="text-end bg-transparent text-muted small uppercase">Pedidos</th>
                                    <th class="text-end bg-transparent text-muted small uppercase">Total</th>
                                    <th class="text-end bg-transparent text-muted small uppercase">%</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var metodo in Model.VentasPorMetodoDePago)
                                {
                                    <tr>
                                        <td class="bg-transparent">
                                            <div class="d-flex align-items-center">
                                                @if (metodo.MetodoDePago.Contains("Mercado"))
                                                {
                                                    <i class="bi bi-wallet2 text-info me-2"></i>
                                                }
                                                else if (metodo.MetodoDePago.Contains("Transferencia"))
                                                {
                                                    <i class="bi bi-bank text-success me-2"></i>
                                                }
                                                else if (metodo.MetodoDePago.Contains("Tarjeta"))
                                                {
                                                    <i class="bi bi-credit-card text-primary me-2"></i>
                                                }
                                                else
                                                {
                                                    <i class="bi bi-cash text-warning me-2"></i>
                                                }
                                                <span class="fw-medium">@metodo.MetodoDePago</span>
                                            </div>
                                        </td>
                                        <td class="text-end bg-transparent">
                                            <span class="fw-semibold">@metodo.CantidadPedidos</span>
                                        </td>
                                        <td class="text-end fw-semibold bg-transparent">
                                            @metodo.TotalVentas.ToString("C", new System.Globalization.CultureInfo("es-CO"))
                                        </td>
                                        <td class="text-end bg-transparent">
                                            <span class="badge bg-primary bg-opacity-10 text-primary">@metodo.PorcentajeDelTotal%</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted text-center py-4">No hay datos disponibles</p>
                }
            </div>
        </div>
    </div>
</div>

<!-- Top Productos y Top Clientes -->
<div class="row g-3 mb-4">
    <!-- Top Productos -->
    <div class="col-12 col-lg-6">
        <div class="card bg-body-tertiary border-0 shadow-sm h-100">
            <div class="card-header bg-transparent border-0 pt-4 pb-3">
                <h5 class="mb-0 fw-semibold">
                    <i class="bi bi-trophy text-primary me-2"></i>
                    Top 5 Productos Más Vendidos
                </h5>
            </div>
            <div class="card-body">
                @if (Model.TopProductos.Any())
                {
                    <div class="list-group list-group-flush">
                        @foreach (var producto in Model.TopProductos.Take(5))
                        {
                            <div class="list-group-item bg-transparent border-0">
                                <div class="d-flex align-items-center">
                                    <img src="@producto.ImagenUrl" alt="@producto.Nombre"
                                         class="rounded me-3" style="width: 50px; height: 50px; object-fit: cover;">
                                    <div class="flex-grow-1">
                                        <h6 class="mb-0">@producto.Nombre</h6>
                                        <small class="text-muted">@producto.Categoria</small>
                                    </div>
                                    <div class="text-center">
                                        <div class="fw-bold">@producto.CantidadVendida</div>
                                        <small class="text-muted">unidades</small>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted text-center py-4">No hay datos disponibles</p>
                }
            </div>
        </div>
    </div>

    <!-- Top Clientes -->
    <div class="col-12 col-lg-6">
        <div class="card bg-body-tertiary border-0 shadow-sm h-100">
            <div class="card-header bg-transparent border-0 pt-4 pb-3">
                <h5 class="mb-0 fw-semibold">
                    <i class="bi bi-star text-primary me-2"></i>
                    Top 5 Mejores Clientes
                </h5>
            </div>
            <div class="card-body">
                @if (Model.TopClientes.Any())
                {
                    <div class="table-responsive bg-transparent">
                        <table class="table table-hover align-middle">
                            <thead>
                                <tr>
                                    <th class="bg-transparent text-muted small uppercase">Cliente</th>
                                    <th class="text-end bg-transparent text-muted small uppercase">Pedidos</th>
                                    <th class="text-end bg-transparent text-muted small uppercase">Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var cliente in Model.TopClientes.Take(5))
                                {
                                    <tr>
                                        <td class="bg-transparent">
                                            <div>
                                                <div class="fw-medium">@cliente.NombreCompleto</div>
                                                <small class="text-muted">@cliente.Email</small>
                                            </div>
                                        </td>
                                        <td class="text-end bg-transparent">
                                            <span class="fw-semibold">@cliente.TotalPedidos</span>
                                        </td>
                                        <td class="text-end fw-semibold bg-transparent">
                                            @cliente.TotalGastado.ToString("C", new System.Globalization.CultureInfo("es-CO"))
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted text-center py-4">No hay datos disponibles</p>
                }
            </div>
        </div>
    </div>
</div>

<!-- Pedidos por Día y Hora -->
<div class="row g-3 mb-4">
    <div class="col-12">
        <div class="card bg-body-tertiary border-0 shadow-sm">
            <div class="card-header bg-transparent border-0 pt-4 pb-3">
                <h5 class="mb-0 fw-semibold">
                    <i class="bi bi-calendar2-week text-primary me-2"></i>
                    Pedidos por Día y Hora
                </h5>
            </div>
            <div class="card-body">
                <canvas id="graficoDiaHora" style="max-height: 350px;"></canvas>
                <script type="application/json" id="datosDiaHora">
                    @Html.Raw(Json.Serialize(Model.VentasPorDiaHora))
                </script>
            </div>
        </div>
    </div>
</div>

<!-- Stock Inmovilizado (Productos "Hueso") -->
<div class="row g-3 mb-4">
    <div class="col-12">
        <div class="card bg-body-tertiary border-0 shadow-sm">
            <div class="card-header bg-transparent border-0 pt-4 pb-3">
                <h5 class="mb-0 fw-semibold">
                    <i class="bi bi-box-seam text-danger me-2"></i>
                    Stock Inmovilizado (sin ventas en 90 días)
                </h5>
            </div>
            <div class="card-body">
                @if (Model.StockInmovilizado != null && Model.StockInmovilizado.Any())
                {
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <p class="text-muted mb-0 small">
                            @Model.StockInmovilizado.Count productos con stock sin ventas en los últimos 90 días
                        </p>
                        <span class="badge bg-danger">
                            $@Model.StockInmovilizado.Sum(s => s.ValorInvertido).ToString("N0", new System.Globalization.CultureInfo("es-CO")) invertido
                        </span>
                    </div>
                    <div class="table-responsive bg-transparent">
                        <table class="table table-hover align-middle">
                            <thead>
                                <tr>
                                    <th class="bg-transparent text-muted small uppercase">Producto</th>
                                    <th class="text-center bg-transparent text-muted small uppercase">Stock</th>
                                    <th class="text-end bg-transparent text-muted small uppercase">Precio</th>
                                    <th class="text-end bg-transparent text-muted small uppercase">Valor Invertido</th>
                                    <th class="text-center bg-transparent text-muted small uppercase">Última Venta</th>
                                    <th class="text-center bg-transparent text-muted small uppercase">Días sin venta</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var producto in Model.StockInmovilizado.Take(15))
                                {
                                    <tr>
                                        <td class="bg-transparent">
                                            <div class="d-flex align-items-center">
                                                <img src="@producto.ImagenUrl" alt="@producto.Nombre"
                                                     class="rounded me-3" style="width: 45px; height: 45px; object-fit: cover;">
                                                <div>
                                                    <div class="fw-medium">@producto.Nombre</div>
                                                    <small class="text-muted">@producto.Categoria</small>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="text-center bg-transparent">
                                            <span class="fw-bold">@producto.Stock</span>
                                        </td>
                                        <td class="text-end bg-transparent">
                                            @producto.Precio.ToString("C", new System.Globalization.CultureInfo("es-CO"))
                                        </td>
                                        <td class="text-end bg-transparent">
                                            <span class="fw-bold text-danger">
                                                @producto.ValorInvertido.ToString("C", new System.Globalization.CultureInfo("es-CO"))
                                            </span>
                                        </td>
                                        <td class="text-center bg-transparent">
                                            @if (producto.UltimaVenta.HasValue)
                                            {
                                                <small class="text-muted">@producto.UltimaVenta.Value.ToString("dd/MM/yyyy")</small>
                                            }
                                            else
                                            {
                                                <small class="text-muted">Nunca</small>
                                            }
                                        </td>
                                        <td class="text-center bg-transparent">
                                            @if (producto.DiasSinVenta > 120)
                                            {
                                                <span class="badge bg-danger">@producto.DiasSinVenta días</span>
                                            }
                                            else if (producto.DiasSinVenta > 90)
                                            {
                                                <span class="badge bg-warning text-dark">@producto.DiasSinVenta días</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">@producto.DiasSinVenta días</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    @if (Model.StockInmovilizado.Count > 15)
                    {
                        <p class="text-muted text-center small mt-2">
                            Mostrando 15 de @Model.StockInmovilizado.Count productos
                        </p>
                    }
                }
                else
                {
                    <p class="text-success text-center py-4">
                        <i class="bi bi-check-circle fs-3 d-block mb-2"></i>
                        Todos los productos con stock han tenido ventas recientes
                    </p>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js" asp-append-version="true"></script>
    <script src="~/js/Features/Reportes/Dashboard.js" asp-append-version="true"></script>
}