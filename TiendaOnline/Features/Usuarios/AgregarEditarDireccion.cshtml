@model TiendaOnline.Features.Usuarios.DireccionViewModel
@{
    ViewData["Title"] = Model.DireccionId > 0 ? "Editar Dirección" : "Agregar Dirección";
}

<div class="container-fluid py-4">
    <nav aria-label="breadcrumb" class="mb-4" style="--bs-breadcrumb-divider: '›'; --bs-breadcrumb-divider-color: #6c757d;">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a asp-controller="Home" asp-action="Index" class="text-decoration-none">
                    <i class="bi bi-house-door me-1"></i>Inicio
                </a>
            </li>
            <li class="breadcrumb-item">
                <a asp-action="PerfilUsuario" asp-route-id="@Model.UsuarioId" class="text-decoration-none">
                    <i class="bi bi-person me-1"></i>Perfil
                </a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">@(Model.DireccionId > 0 ? "Editar Dirección" : "Agregar Dirección")</li>
        </ol>
    </nav>

    <partial name="_TituloSeccion" model='(Model.DireccionId > 0 ? "Editar Dirección" : "Agregar Dirección", Model.DireccionId > 0 ? $"Editando: {Model.Etiqueta}" : "Nueva dirección de entrega")' />

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card rounded-3 border-1 overflow-hidden">
                <div class="card-header bg-transparent p-3 border-bottom">
                    <h5 class="mb-0 fw-semibold">
                        <i class="bi bi-geo-alt me-2 text-primary"></i>
                        @(Model.DireccionId > 0 ? "Datos de la dirección" : "Datos de la nueva dirección")
                    </h5>
                </div>
                <div class="card-body p-4">
                    @{
                        var actionName = Model.DireccionId > 0 ? "EditarDireccion" : "AgregarDireccion";
                        var routeId = Model.DireccionId > 0 ? Model.DireccionId : Model.UsuarioId;
                    }
                    <form asp-action="@actionName" asp-route-id="@routeId" method="post" id="formularioDireccion" novalidate>
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="DireccionId" />
                        <input type="hidden" asp-for="UsuarioId" />

                        <div class="mb-4">
                            <h6 class="text-muted mb-3 fw-semibold">
                                <i class="bi bi-tag me-2"></i>Identificación
                            </h6>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <div class="form-floating">
                                        <input asp-for="Etiqueta" class="form-control" placeholder="Ej: Casa, Trabajo" />
                                        <label for="Etiqueta">
                                            <i class="bi bi-tag me-1"></i>Etiqueta (Ej: Casa, Trabajo)
                                        </label>
                                        <span asp-validation-for="Etiqueta" class="text-danger small mt-1"></span>
                                    </div>
                                </div>
                                <div class="col-md-6 d-flex align-items-end">
                                    <div class="form-check mb-3">
                                        <input asp-for="EsPrincipal" class="form-check-input" />
                                        <label asp-for="EsPrincipal" class="form-check-label">
                                            <i class="bi bi-star me-1"></i>Marcar como principal
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="mb-4">
                            <h6 class="text-muted mb-3 fw-semibold">
                                <i class="bi bi-geo me-2"></i>Dirección
                            </h6>
                            <div class="row g-3">
                                <div class="col-md-8">
                                    <div class="form-floating">
                                        <input asp-for="Calle" class="form-control" placeholder="Calle" />
                                        <label for="Calle">
                                            <i class="bi bi-signpost me-1"></i>Calle
                                        </label>
                                        <span asp-validation-for="Calle" class="text-danger small mt-1"></span>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-floating">
                                        <input asp-for="Numero" class="form-control" placeholder="Número" />
                                        <label for="Numero">
                                            <i class="bi bi-hash me-1"></i>Número
                                        </label>
                                        <span asp-validation-for="Numero" class="text-danger small mt-1"></span>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-floating">
                                        <input asp-for="Piso" class="form-control" placeholder="Piso" />
                                        <label for="Piso">
                                            <i class="bi bi-building me-1"></i>Piso (opcional)
                                        </label>
                                        <span asp-validation-for="Piso" class="text-danger small mt-1"></span>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-floating">
                                        <input asp-for="Departamento" class="form-control" placeholder="Departamento" />
                                        <label for="Departamento">
                                            <i class="bi bi-door-open me-1"></i>Depto. (opcional)
                                        </label>
                                        <span asp-validation-for="Departamento" class="text-danger small mt-1"></span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="mb-4">
                            <h6 class="text-muted mb-3 fw-semibold">
                                <i class="bi bi-map me-2"></i>Ubicación
                            </h6>
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <div class="form-floating">
                                        <select asp-for="Provincia" id="selectProvincia" class="form-select">
                                            <option value="">Seleccione una provincia...</option>
                                            @if (Model.DireccionId > 0 && !string.IsNullOrEmpty(Model.Provincia))
                                            {
                                                <option value="@Model.Provincia" selected>@Model.Provincia</option>
                                            }
                                        </select>
                                        <label for="selectProvincia">
                                            <i class="bi bi-geo me-1"></i>Provincia
                                        </label>
                                        <span asp-validation-for="Provincia" class="text-danger small mt-1"></span>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-floating">
                                        <select asp-for="Localidad" id="selectLocalidad" class="form-select" disabled>
                                            <option value="">Primero elija una provincia...</option>
                                            @if (Model.DireccionId > 0 && !string.IsNullOrEmpty(Model.Localidad))
                                            {
                                                <option value="@Model.Localidad" selected>@Model.Localidad</option>
                                            }
                                        </select>
                                        <label for="selectLocalidad">
                                            <i class="bi bi-building me-1"></i>Localidad
                                        </label>
                                        <span asp-validation-for="Localidad" class="text-danger small mt-1"></span>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-floating">
                                        <input asp-for="CodigoPostal" class="form-control" placeholder="Código Postal" />
                                        <label for="CodigoPostal">
                                            <i class="bi bi-mailbox me-1"></i>Código Postal
                                        </label>
                                        <span asp-validation-for="CodigoPostal" class="text-danger small mt-1"></span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="mb-4">
                            <h6 class="text-muted mb-3 fw-semibold">
                                <i class="bi bi-chat-text me-2"></i>Observaciones
                            </h6>
                            <div class="row g-3">
                                <div class="col-12">
                                    <div class="form-floating">
                                        <textarea asp-for="Observaciones" class="form-control" placeholder="Observaciones" style="height: 100px"></textarea>
                                        <label for="Observaciones">
                                            <i class="bi bi-chat-text me-1"></i>Observaciones (opcional)
                                        </label>
                                        <span asp-validation-for="Observaciones" class="text-danger small mt-1"></span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex flex-column flex-md-row align-items-stretch align-items-md-center pt-3 border-top gap-2">
                            <a asp-controller="Usuarios" asp-action="PerfilUsuario" asp-route-id="@Model.UsuarioId" class="btn btn-outline-danger">
                                <i class="bi bi-x-circle me-1"></i>Cancelar
                            </a>
                            <button type="button"
                                    id="btnRestablecer"
                                    class="btn btn-outline-secondary px-4">
                                <i class="bi bi-arrow-clockwise me-2"></i>Restablecer
                            </button>
                            <button type="submit" class="btn btn-primary px-4 ms-md-auto" id="botonGuardar">
                                <i class="bi bi-check-circle me-2"></i>
                                <span class="texto-boton">@(Model.DireccionId > 0 ? "Guardar Cambios" : "Agregar Dirección")</span>
                                <span class="spinner-border spinner-border-sm ms-2 d-none" role="status" aria-hidden="true"></span>
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts{
    <script src="~/js/Features/Usuarios/AgregarEditarDireccion.js" asp-append-version="true"></script>
}
