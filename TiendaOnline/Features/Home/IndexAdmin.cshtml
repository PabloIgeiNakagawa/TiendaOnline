@using TiendaOnline.Features.Home
@model HomeAdminViewModel
@{
    ViewData["Title"] = "Inicio";
}
@section Styles{
    <style>
        .luz-parpadeante {
            box-shadow: 0 0 0 0 rgba(40, 167, 69, 0.7); /* Color verde por defecto */
            animation: pulso-verde 2s infinite;
        }

        /* Si está offline (rojo), cambiamos el color del pulso */
        .bg-danger.luz-parpadeante {
            box-shadow: 0 0 0 0 rgba(220, 53, 69, 0.7);
            animation: pulso-rojo 2s infinite;
        }

        @@keyframes pulso-verde {
            0% {
                transform: translate(-50%, -50%) scale(0.95);
                box-shadow: 0 0 0 0 rgba(40, 167, 69, 0.7);
            }

            70% {
                transform: translate(-50%, -50%) scale(1);
                box-shadow: 0 0 0 10px rgba(40, 167, 69, 0);
            }

            100% {
                transform: translate(-50%, -50%) scale(0.95);
                box-shadow: 0 0 0 0 rgba(40, 167, 69, 0);
            }
        }

        @@keyframes pulso-rojo {
            0% {
                transform: translate(-50%, -50%) scale(0.95);
                box-shadow: 0 0 0 0 rgba(220, 53, 69, 0.7);
            }

            70% {
                transform: translate(-50%, -50%) scale(1);
                box-shadow: 0 0 0 10px rgba(220, 53, 69, 0);
            }

            100% {
                transform: translate(-50%, -50%) scale(0.95);
                box-shadow: 0 0 0 0 rgba(220, 53, 69, 0);
            }
        }
    </style>
}

<div class="container-fluid py-4">
    <div class="d-md-flex justify-content-md-between align-items-md-center mb-4">
        <partial name="_TituloSeccion" model='("Panel de Control", "Estado operativo del sistema en tiempo real")' />

        <div class="d-flex gap-2">
            <span class="badge rounded-pill border border-secondary p-2 px-3 position-relative @((Model.EstaDbOnline ? "bg-success" : "bg-danger"))">
                <i class="bi bi-database-fill me-1"></i>
                DB: @(Model.EstaDbOnline ? "Online" : "Offline")

                <span class="position-absolute top-0 start-100 translate-middle p-1 @((Model.EstaDbOnline ? "bg-success" : "bg-danger")) border border-light rounded-circle @((Model.EstaDbOnline ? "luz-parpadeante" : ""))">
                    <span class="visually-hidden">Estado</span>
                </span>
            </span>
            <span class="badge rounded-pill bg-secondary border border-secondary p-2 px-3">
                App version: v@(Model.VersionApp)
            </span>
        </div>
    </div>

    <!-- Resumen Diario -->
    <div class="row g-3 mb-4">
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="card bg-body-tertiary border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted mb-1 small">Ventas hoy</p>
                            <h3 class="mb-0 fw-bold">@Model.ResumenDiario.FormatoMoneda(Model.ResumenDiario.VentasHoy)</h3>
                        </div>
                        <div class="bg-success bg-opacity-10 rounded-3 p-2">
                            <i class="bi bi-currency-dollar text-success fs-4"></i>
                        </div>
                    </div>
                    <div class="mt-2">
                        @if (Model.ResumenDiario.PorcentajeVentas >= 0)
                        {
                            <span class="badge bg-success bg-opacity-10 text-success">
                                <i class="bi bi-arrow-up"></i> @Model.ResumenDiario.PorcentajeVentas.ToString("F1")%
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-danger bg-opacity-10 text-danger">
                                <i class="bi bi-arrow-down"></i> @Math.Abs(Model.ResumenDiario.PorcentajeVentas).ToString("F1")%
                            </span>
                        }
                        <small class="text-muted ms-1">vs ayer</small>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="card bg-body-tertiary border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted mb-1 small">Pedidos hoy</p>
                            <h3 class="mb-0 fw-bold">@Model.ResumenDiario.PedidosHoy</h3>
                        </div>
                        <div class="bg-primary bg-opacity-10 rounded-3 p-2">
                            <i class="bi bi-receipt text-primary fs-4"></i>
                        </div>
                    </div>
                    <div class="mt-2">
                        @if (Model.ResumenDiario.PorcentajePedidos >= 0)
                        {
                            <span class="badge bg-success bg-opacity-10 text-success">
                                <i class="bi bi-arrow-up"></i> @Model.ResumenDiario.PorcentajePedidos.ToString("F1")%
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-danger bg-opacity-10 text-danger">
                                <i class="bi bi-arrow-down"></i> @Math.Abs(Model.ResumenDiario.PorcentajePedidos).ToString("F1")%
                            </span>
                        }
                        <small class="text-muted ms-1">vs ayer</small>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="card bg-body-tertiary border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted mb-1 small">Enviados hoy</p>
                            <h3 class="mb-0 fw-bold">@Model.ResumenDiario.EnviadosHoy</h3>
                        </div>
                        <div class="bg-info bg-opacity-10 rounded-3 p-2">
                            <i class="bi bi-truck text-info fs-4"></i>
                        </div>
                    </div>
                    <div class="mt-2">
                        @if (Model.ResumenDiario.PorcentajeEnviados >= 0)
                        {
                            <span class="badge bg-success bg-opacity-10 text-success">
                                <i class="bi bi-arrow-up"></i> @Model.ResumenDiario.PorcentajeEnviados.ToString("F1")%
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-danger bg-opacity-10 text-danger">
                                <i class="bi bi-arrow-down"></i> @Math.Abs(Model.ResumenDiario.PorcentajeEnviados).ToString("F1")%
                            </span>
                        }
                        <small class="text-muted ms-1">vs ayer</small>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="card bg-body-tertiary border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted mb-1 small">Stock bajo</p>
                            <h3 class="mb-0 fw-bold">@Model.ResumenDiario.StockBajo</h3>
                        </div>
                        <div class="bg-warning bg-opacity-10 rounded-3 p-2">
                            <i class="bi bi-exclamation-triangle text-warning fs-4"></i>
                        </div>
                    </div>
                    <div class="mt-2">
                        <small class="text-muted">productos con menos de 5 unidades</small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Cards de 3 columnas -->
    <div class="row g-3">
        <!-- Columna 1: Productos Bajo Stock -->
        <div class="col-12 col-lg-4">
            @if (Model.ProductosBajoStock.Any())
            {
                <div class="card bg-body-tertiary border-0 shadow-sm h-100">
                    <div class="card-header bg-transparent border-0 pt-4 pb-3">
                        <h5 class="mb-0 fw-semibold">
                            <i class="bi bi-exclamation-triangle text-warning me-2"></i>
                            Productos con Bajo Stock
                        </h5>
                    </div>
                    <div class="card-body" style="max-height: 400px; overflow-y: auto;">
                        <div class="row g-3">
                            @foreach (var producto in Model.ProductosBajoStock)
                            {
                                <div class="col-12 col-sm-6 col-lg-12">
                                    <div class="d-flex align-items-center">
                                        <img src="@producto.ImagenUrl" alt="@producto.Nombre"
                                             class="rounded me-3" style="width: 45px; height: 45px; object-fit: cover;">
                                        <div class="flex-grow-1">
                                            <h6 class="mb-0">@producto.Nombre</h6>
                                            <small class="text-muted">@producto.Categoria</small>
                                        </div>
                                        <div class="text-end">
                                            <span class="badge @producto.BadgeClase">@producto.BadgeTexto</span>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Columna 2: Actividad Reciente -->
        <div class="col-12 col-lg-4">
            <div class="card border-0 shadow-sm bg-body-tertiary h-100">
                <div class="card-header bg-transparent border-0 pt-4 pb-3">
                    <h5 class="mb-0 fw-semibold">
                        <i class="bi bi-journal-text me-2 text-primary"></i>Actividad Reciente
                    </h5>
                </div>
                <div class="card-body">
                    <div class="position-relative ps-4">
                        <div class="position-absolute top-0 bottom-0 start-0 border-start border-secondary-subtle" style="margin-left: 10px;"></div>

                        @foreach (var cambio in Model.UltimosCambios.Take(5))
                        {
                            <div class="position-relative mb-3">
                                <div class="position-absolute top-0 start-0 translate-middle-x bg-primary rounded-circle shadow"
                                     style="width: 12px; height: 12px; margin-left: -13px; margin-top: 6px; z-index: 2;"></div>

                                <div class="ms-3">
                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                        <h6 class="mb-0">@cambio.Usuario</h6>
                                        <span class="badge rounded-pill border border-secondary-subtle text-secondary fw-normal">
                                            <i class="bi bi-clock me-1"></i> @cambio.FechaRelativa
                                        </span>
                                    </div>
                                    <p class="mb-1 text-body-secondary small">@cambio.Accion</p>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Columna 3: Atención Requerida -->
        <div class="col-12 col-lg-4">
            <div class="card border-0 shadow-sm bg-body-tertiary h-100">
                <div class="card-header bg-transparent border-0 pt-4 pb-3">
                    <h5 class="mb-0 fw-semibold">
                        <i class="bi bi-exclamation-triangle-fill me-2 text-warning"></i>Atención Requerida
                        <span class="badge bg-danger">@Model.TotalRegistros</span>
                    </h5>
                </div>
                <div class="card-body overflow-y-auto" id="pedidos-estancados-container"
                     data-pagina-actual="@Model.PaginaActual"
                     data-total-paginas="@Model.TotalPaginas"
                     data-total-registros="@Model.TotalRegistros">
                    <!-- Contenido cargado dinámicamente via JS -->
                </div>
            </div>
        </div>
    </div>

    <!-- Movimientos de Stock -->
    <div class="row g-3 mt-3">
        <div class="col-12">
            <div class="card border-0 shadow-sm bg-body-tertiary">
                <div class="card-header bg-transparent border-0 pt-4 pb-3">
                    <h5 class="mb-0 fw-semibold">
                        <i class="bi bi-box-seam me-2 text-primary"></i>Movimientos de Stock Recientes
                    </h5>
                </div>
                <div class="card-body p-0">
                    @if (!Model.UltimosMovimientosStock.Any())
                    {
                        <div class="text-center py-3">
                            <i class="bi bi-box-seam fs-1 text-muted opacity-50"></i>
                            <p class="text-muted mt-2 small">No hay movimientos de stock registrados</p>
                        </div>
                    }
                    else
                    {
                        <div class="row row-cols-1 row-cols-sm-2 g-2 p-2">
                            @foreach (var mov in Model.UltimosMovimientosStock)
                            {
                                <div class="col">
                                    <div class="card bg-body-tertiary border border-secondary-subtle border-1 h-100">
                                        <div class="card-body py-2">
                                            <div class="d-flex justify-content-between align-items-center mb-1">
                                                <span class="small">@mov.ProductoNombre</span>
                                                <span class="badge @(mov.Cantidad > 0 ? "bg-success" : "bg-danger")">
                                                    @(mov.Cantidad > 0 ? "+" : "")@mov.Cantidad
                                                </span>
                                            </div>
                                            <div class="d-flex justify-content-between align-items-center">
                                                <partial name="_TipoMovimientoBadge" model="@mov.TipoMovimiento" />
                                                <span class="small text-muted">@mov.FechaRelativa</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Pedidos Recientes -->
    <div class="row g-3 mt-3">
        <div class="col-12">
            <div class="card border-0 shadow-sm bg-body-tertiary">
                <div class="card-header bg-transparent border-0 pt-4 pb-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0 fw-semibold">
                            <i class="bi bi-clock-history text-primary me-2"></i>
                            Pedidos Recientes
                        </h5>
                        <a asp-controller="AdminPedidos" asp-action="Listado" class="btn btn-sm btn-outline-primary">
                            Ver todos <i class="bi bi-arrow-right ms-1"></i>
                        </a>
                    </div>
                </div>
                <div class="card-body">
                @if (Model.PedidosRecientes.Any())
                {
                    <!-- Table desktop -->
                    <div class="table-responsive d-none d-lg-block">
                        <table class="table table-hover align-middle mb-0 bg-transparent">
                            <thead>
                                <tr>
                                    <th class="bg-transparent text-muted small uppercase">ID</th>
                                    <th class="bg-transparent text-muted small uppercase">Cliente</th>
                                    <th class="bg-transparent text-muted small uppercase">Fecha</th>
                                    <th class="bg-transparent text-end text-muted small uppercase">Total</th>
                                    <th class="bg-transparent text-center text-muted small uppercase">Estado</th>
                                    <th class="bg-transparent text-center text-muted small uppercase"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var pedido in Model.PedidosRecientes)
                                {
                                    <tr>
                                        <td class="fw-medium bg-transparent">#@pedido.PedidoId</td>
                                        <td class="bg-transparent">@pedido.Cliente</td>
                                        <td class="bg-transparent">@pedido.FechaPedido.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td class="text-end fw-semibold bg-transparent">@pedido.Total.ToString("C")</td>
                                        <td class="text-center bg-transparent">
                                            <span class="badge @pedido.EstadoBadge">@pedido.EstadoPedido</span>
                                        </td>
                                        <td class="text-center bg-transparent">
                                            <a asp-controller="Pedidos" asp-action="Detalles" asp-route-id="@pedido.PedidoId"
                                               class="btn btn-sm btn-outline-primary" data-bs-toggle="tooltip" title="Ver detalle">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <!-- Cards mobile -->
                    <div class="d-lg-none">
                        @foreach (var pedido in Model.PedidosRecientes)
                        {
                            <div class="card bg-body-tertiary border border-secondary-subtle border-1 mb-2">
                                <div class="card-body py-2">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <span class="fw-semibold">#@pedido.PedidoId</span>
                                        <span class="badge @pedido.EstadoBadge">@pedido.EstadoPedido</span>
                                    </div>
                                    <div class="small text-muted mb-1">@pedido.Cliente</div>
                                    <div class="d-flex justify-content-between align-items-center">
                                        <small class="text-muted">@pedido.FechaPedido.ToString("dd/MM/yyyy HH:mm")</small>
                                        <span class="fw-semibold">@pedido.Total.ToString("C")</span>
                                    </div>
                                    <div class="text-end mt-2">
                                        <a asp-controller="Pedidos" asp-action="Detalles" asp-route-id="@pedido.PedidoId"
                                           class="btn btn-sm btn-outline-primary" data-bs-toggle="tooltip" title="Ver detalle">
                                            <i class="bi bi-eye me-1"></i>Ver
                                        </a>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted text-center py-3">No hay pedidos recientes</p>
                }
            </div>
        </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/Features/Home/IndexAdmin.js" asp-append-version="true"></script>
}