@{
    ViewData["Title"] = "Demasiados intentos";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="card border-0 shadow-sm">
                <div class="card-body py-5">
                    <div class="mb-4">
                        <i class="bi bi-hourglass-split text-warning" style="font-size: 4rem;"></i>
                    </div>
                    <h2 class="mb-3 fw-bold">Demasiados intentos</h2>
                    <p class="text-muted mb-4">
                        Has realizado demasiadas solicitudes. Por favor, espera un momento y vuelve a intentar.
                    </p>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg">
                        <i class="bi bi-house-door me-2"></i>Volver al inicio
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
