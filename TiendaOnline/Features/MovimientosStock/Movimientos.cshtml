@using TiendaOnline.Features.MovimientosStock
@using TiendaOnline.Features.Shared.ViewModels
@model MovimientosViewModel

<div class="container-fluid py-4">
    <partial name="_TituloSeccion" model='("Movimientos de Stock", "Historial de entradas, salidas y ajustes de inventario")' />

    <form method="get" asp-action="Movimientos">
        <div class="row mb-4">
            <div class="col-12">
                <div class="card rounded-3 border">
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-1">
                                <label class="form-label fw-bold text-muted small">Ver</label>
                                <select name="RegistrosPorPagina" class="form-select" onchange="this.form.submit()">
                                    @{
                                        int[] opciones = { 20, 50, 100 };
                                        foreach (var cantidad in opciones)
                                        {
                                            <option value="@cantidad" selected="@(Model.RegistrosPorPagina == cantidad ? "selected" : null)">
                                                @cantidad
                                            </option>
                                        }
                                    }
                                </select>
                            </div>

                            <div class="col-md-3">
                                <label class="form-label fw-semibold"><i class="bi bi-search me-1"></i>Producto</label>
                                <input type="text" name="Busqueda" value="@Model.Busqueda" class="form-control" placeholder="Nombre del producto...">
                            </div>

                            <div class="col-md-2">
                                <label class="form-label fw-semibold"><i class="bi bi-funnel me-1"></i>Tipo</label>
                                <select name="TipoMovimientoId" class="form-select">
                                    <option value="">Todos</option>
                                    @foreach (var tipo in Model.TiposMovimiento)
                                    {
                                        <option value="@tipo.Id" selected="@(Model.TipoMovimientoId == tipo.Id)">@tipo.Nombre</option>
                                    }
                                </select>
                            </div>

                            <div class="col-md-2">
                                <label class="form-label fw-semibold"><i class="bi bi-calendar-event me-1"></i>Desde</label>
                                <input type="date" name="Desde" value="@(Model.Desde?.ToString("yyyy-MM-dd"))" class="form-control">
                            </div>

                            <div class="col-md-2">
                                <label class="form-label fw-semibold"><i class="bi bi-calendar-event me-1"></i>Hasta</label>
                                <input type="date" name="Hasta" value="@(Model.Hasta?.ToString("yyyy-MM-dd"))" class="form-control">
                            </div>

                            <div class="col-md-2 d-flex align-items-end gap-2">
                                <button type="submit" class="btn btn-primary rounded-3 flex-fill">
                                    <i class="bi bi-filter"></i>
                                </button>
                                <a asp-action="Movimientos" class="btn btn-outline-secondary rounded-3 flex-fill" title="Limpiar filtros">
                                    <i class="bi bi-arrow-clockwise"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>

    <partial name="_ResumenResultados" model="Model.ResumenFiltros" />

    <!-- Tabla -->
    <div class="d-none d-lg-block">
        <table class="table table-hover mb-0 align-middle">
            <thead>
                <tr>
                    <th class="border-0 py-3 ps-4"><i class="bi bi-box me-2 text-primary"></i>Producto</th>
                    <th class="border-0 py-3"><i class="bi bi-funnel me-2 text-primary"></i>Tipo</th>
                    <th class="border-0 py-3 text-center"><i class="bi bi-123 me-2 text-primary"></i>Cantidad</th>
                    <th class="border-0 py-3"><i class="bi bi-calendar me-2 text-primary"></i>Fecha</th>
                    <th class="border-0 py-3"><i class="bi bi-cart-check me-2 text-primary"></i>Pedido</th>
                    <th class="border-0 py-3"><i class="bi bi-chat-left-text me-2 text-primary"></i>Observaciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.MovimientosPaginados.Items)
                {
                    <tr>
                        <td class="ps-4">
                            <div class="d-flex align-items-center">
                                <img src="@item.ImagenUrl"
                                     alt="@item.ProductoNombre"
                                     class="rounded border me-3 img-producto-modal"
                                     data-url="@item.ImagenUrl"
                                     data-titulo="@item.ProductoNombre"
                                     style="width: 40px; height: 40px; object-fit: cover; cursor: zoom-in;">
                                <span class="fw-semibold">@item.ProductoNombre</span>
                            </div>
                        </td>
                        <td>
                            @if (item.Tipo.ToLower().Contains("entrada"))
                            {
                                <span class="badge bg-success bg-opacity-10 text-success px-3 py-2 rounded-pill border border-success border-opacity-25">
                                    <i class="bi bi-arrow-down-circle me-1"></i>@item.Tipo
                                </span>
                            }
                            else if (item.Tipo.ToLower().Contains("salida"))
                            {
                                <span class="badge bg-danger bg-opacity-10 text-danger px-3 py-2 rounded-pill border border-danger border-opacity-25">
                                    <i class="bi bi-arrow-up-circle me-1"></i>@item.Tipo
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-warning bg-opacity-10 text-warning px-3 py-2 rounded-pill border border-warning border-opacity-25">
                                    <i class="bi bi-pencil-square me-1"></i>@item.Tipo
                                </span>
                            }
                        </td>
                        <td class="text-center">
                            <span class="fw-bold @(item.Cantidad < 0 ? "text-danger" : "text-success")">
                                @(item.Cantidad < 0 ? "" : "+")@item.Cantidad
                            </span>
                        </td>
                        <td class="text-muted small">
                            <div><i class="bi bi-calendar3 me-1"></i>@item.Fecha.ToString("dd/MM/yyyy")</div>
                            <div><i class="bi bi-clock me-1"></i>@item.Fecha.ToString("HH:mm")</div>
                        </td>
                        <td>
                            @if (item.PedidoId.HasValue)
                            {
                                <a asp-controller="Pedidos" asp-action="Detalles" asp-route-id="@item.PedidoId"
                                   class="d-flex justify-content-center align-items-center fw-semibold text-uppercase"
                                   style="font-size: 0.9rem; letter-spacing: 0.5px;"
                                   data-bs-toggle="tooltip"
                                   data-bs-placement="top"
                                   data-bs-title="Ver detalles del pedido">
                                    #@item.PedidoId
                                </a>
                            }
                            else
                            {
                                <span class="d-flex justify-content-center align-items-center fw-semibold">-</span>
                            }
                        </td>
                        <td class="text-muted small text-truncate" style="max-width: 200px;" title="@item.Observaciones">
                            @item.Observaciones
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="d-lg-none p-3">
        @foreach (var item in Model.MovimientosPaginados.Items)
        {
            <div class="card mb-3 border shadow-sm">
                <div class="card-body">
                    <div class="d-flex mb-3">
                        <img src="@item.ImagenUrl" class="rounded me-3" style="width: 60px; height: 60px; object-fit: cover;">
                        <div>
                            <h6 class="mb-1 fw-bold">@item.ProductoNombre</h6>
                            <small class="text-muted">@item.Fecha.ToString("dd/MM/yyyy HH:mm")</small>
                        </div>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="badge @(item.Tipo.ToLower().Contains("salida") ? "bg-danger" : "bg-success")">
                            @item.Tipo
                        </span>
                        <span class="fw-bold fs-5 @(item.Cantidad < 0 ? "text-danger" : "text-success")">
                            @(item.Cantidad < 0 ? "" : "+")@item.Cantidad
                        </span>
                    </div>
                    <div class="p-2 rounded small text-muted">
                        <i class="bi bi-cart-check me-1 text-primary"></i> @item.PedidoId <br />
                        <i class="bi bi-chat-left-text me-1 text-primary"></i> @item.Observaciones
                    </div>
                </div>
            </div>
        }
    </div>

    <partial name="_Paginacion" model="@(new PaginacionViewModel { 
        PaginaActual = Model.MovimientosPaginados.PaginaActual, 
        TotalPaginas = Model.MovimientosPaginados.TotalPaginas,
        Accion = "Movimientos"
    })" />
</div>

<div class="modal fade" id="modalImagenProducto" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-body p-0 text-center position-relative bg-dark rounded">
                <button type="button" class="btn-close btn-close-white position-absolute top-0 end-0 m-3" data-bs-dismiss="modal"></button>
                <img id="imgModalSrc" src="" class="img-fluid rounded" style="max-height: 80vh;">
                <h6 id="imgModalTitle" class="text-white py-2 m-0"></h6>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/Features/MovimientosStock/Movimientos.js" asp-append-version="true"></script>
}