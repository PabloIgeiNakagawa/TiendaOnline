@model (string TituloPrincipal, string Subtitulo)

<div class="row mb-4">
    <div class="col-12">
        <div class="d-flex align-items-center border-start border-primary border-4 ps-4">
            <div>
                <h2 class="display-6 fw-black text-primary text-uppercase tracking-widest mb-1" style="letter-spacing: 2px;">
                    @Model.TituloPrincipal
                </h2>
                <p class="text-secondary small text-uppercase mb-0">@Model.Subtitulo</p>
            </div>
        </div>
    </div>
</div>