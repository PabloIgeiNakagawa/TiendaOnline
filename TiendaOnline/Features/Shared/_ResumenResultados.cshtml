@using TiendaOnline.Features.Shared.ViewModels
@model ResumenResultadosViewModel
@{
    var queryLimpia = new Dictionary<string, string>();
    if (Context.Request.Query.ContainsKey("RegistrosPorPagina"))
    {
        queryLimpia.Add("RegistrosPorPagina", Context.Request.Query["RegistrosPorPagina"]);
        queryLimpia.Add("pagina", "1");
    }
}

<!-- Filtros aplicados -->
<div class="d-flex flex-wrap align-items-center gap-2 @(Model.TotalRegistros > 0 ? "mb-2" : "mb-4")">
    @if (Model.Filtros.Any())
    {
        <span class="small text-muted me-1">Filtros:</span>
        @foreach (var filtro in Model.Filtros)
        {
            // Clonamos TODOS los parámetros que están actualmente en la URL
            var routeData = Context.Request.Query.ToDictionary(
            k => k.Key,
            v =>
                {
                    // StringValues puede contener múltiples valores, pero aquí asumimos el primero
                    var valueStr = v.Value.ToString();
                    DateTime dt;
                    // Intentamos analizar como fecha, si es posible
                    if (DateTime.TryParse(valueStr, out dt))
                    {
                        return dt.ToString("yyyy-MM-dd");
                    }
                    return valueStr;
                }
            ); // Para evitar cambios de formato en la fecha.

            // Removemos de la URL el parámetro de ESTE badge y la página (para volver a la 1)
            if (!string.IsNullOrEmpty(filtro.Propiedad))
            {
                routeData.Remove(filtro.Propiedad);
            }

            <div class="badge rounded-pill bg-secondary-subtle text-secondary-emphasis border border-secondary-subtle d-flex align-items-center px-3 py-2">
                <i class="bi @filtro.Icono me-2"></i>
                <span class="fw-normal">@filtro.Etiqueta: <strong>@filtro.Valor</strong></span>
                <a asp-action="@Model.ActionName"
                   asp-all-route-data="routeData"
                   asp-route-pagina="1"
                   title="Quitar filtro"
                   class="ms-2 text-secondary-emphasis d-inline-flex align-items-center text-decoration-none">
                    <i class="bi bi-x-circle-fill opacity-50 hover-opacity-100"></i>
                </a>
            </div>
        }

        <a asp-action="@Model.ActionName" asp-all-route-data="@queryLimpia" class="btn btn-link btn-sm text-danger text-decoration-none fw-bold ms-1">
            <i class="bi bi-trash3 me-1"></i>Limpiar todo
        </a>
    }
</div>

<!-- Cantidad de resultados -->
<div class="d-flex flex-column flex-md-row align-items-md-center gap-3 py-3 border-bottom mb-3">
    <div class="text-secondary">
        @if (Model.TotalRegistros > 0)
        {
            <p class="mb-0 small">
                Mostrando <span class="fw-semibold">@Model.Desde - @Model.Hasta</span>
                de <span class="fw-semibold">@Model.TotalRegistros</span> @Model.NombreEntidad
            </p>
        }
        else
        {
            <div class="d-flex align-items-center text-warning bg-warning-subtle px-3 py-2 rounded-2 border border-warning-subtle">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                <span class="small fw-semibold">No se encontraron @Model.NombreEntidad que coincidan con la búsqueda.</span>
            </div>
        }
    </div>
</div>