@using System.Security.Claims
@{
    var nombreUsuario = User?.FindFirstValue(ClaimTypes.Name);
}
@functions {
    // Definición del objeto de navegación
    public class AdminNavLink
    {
        public string Controller { get; set; }
        public string Action { get; set; }
        public string Icon { get; set; }
        public string Text { get; set; }
        public string? GroupName { get; set; }
    }

    // Lógica mejorada para clase activa: compara controller+action y, si el link tiene GroupName,
    // compara también con valores en route data o query string (soporta varios nombres comunes).
    public string ActiveClass(string controller, string action, string? groupName = null)
    {
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();

        if (!string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase) ||
            !string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase))
        {
            return "";
        }

        // Si el link NO tiene GroupName -> se activa por controller+action solamente
        if (string.IsNullOrWhiteSpace(groupName))
        {
            return "active bg-primary-subtle text-primary";
        }

        // Buscar en RouteData o QueryString el nombre del grupo/section/tab que use tu controlador
        var possibleKeys = new[] { "group", "groupName", "section", "tab", "settingGroup" };
        string? currentGroup = null;

        foreach (var key in possibleKeys)
        {
            if (ViewContext.RouteData.Values.TryGetValue(key, out var v) && v != null)
            {
                currentGroup = v.ToString();
                break;
            }
        }

        if (currentGroup == null)
        {
            var q = ViewContext.HttpContext.Request.Query;
            foreach (var key in possibleKeys)
            {
                if (q.TryGetValue(key, out var vals) && vals.Count > 0)
                {
                    currentGroup = vals[0];
                    break;
                }
            }
        }

        return string.Equals(currentGroup, groupName, StringComparison.OrdinalIgnoreCase)
            ? "active bg-primary-subtle text-primary"
            : "";
    }
}
@{
    var gestionTiendaLinks = new List<AdminNavLink>
    {
        new() { Controller = "AdminReportes", Action = "Dashboard", Icon = "bi-bar-chart-line", Text = "Reportes" },
        new() { Controller = "AdminProductos", Action = "Catalogo", Icon = "bi-box-seam", Text = "Productos" },
        new() { Controller = "Categorias", Action = "Listado", Icon = "bi-tags", Text = "Categorías" },
        new() { Controller = "AdminUsuarios", Action = "Listado", Icon = "bi-people", Text = "Usuarios" }
    };

    var operacionesLinks = new List<AdminNavLink>
    {
        new() { Controller = "AdminPedidos", Action = "Listado", Icon = "bi-cart-check", Text = "Pedidos" },
        new() { Controller = "AdminAuditorias", Action = "Logs", Icon = "bi-shield-check", Text = "Auditoría" },
        new() { Controller = "MovimientosStock", Action = "Movimientos", Icon = "bi-arrow-left-right", Text = "Stock" }
    };

    var configLinks = new List<AdminNavLink>
    {
        new() { Controller = "AppSettings", Action = "Estetica", Icon = "bi-gear", Text = "Apariencia" },
        new() { Controller = "AppSettings", Action = "Index", Icon = "bi-chat-dots", Text = "Contacto", GroupName = "Contacto"},
        new() { Controller = "AppSettings", Action = "Index", Icon = "bi-search", Text = "SEO", GroupName = "SEO"},
        new() { Controller = "AppSettings", Action = "Index", Icon = "bi-credit-card", Text = "Pagos", GroupName = "Pagos"}
    };
}
<!DOCTYPE html>
<html lang="es" class="h-100">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - @AppSettings.GetValue("Diseno:NombreDelSitio")</title>
    <meta name="description" content="@AppSettings.GetValue("Seo:Descripcion")">
    <meta name="keywords" content="@AppSettings.GetValue("Seo:Palabras claves")">
    <meta name="author" content="@AppSettings.GetValue("Seo:Autor")">
    <meta name="description" content="@AppSettings.GetValue("Seo:Descripcion")">

    <meta property="og:site_name" content="@AppSettings.GetValue("Diseno:NombreDelSitio")" />
    <meta property="og:title" content="@AppSettings.GetValue("OpenGraph:Titulo")">
    <meta property="og:description" content="@AppSettings.GetValue("OpenGraph:Descripcion")">
    <meta property="og:image" content="@AppSettings.GetValue("OpenGraph:ImagenUrl")">
    <meta property="og:type" content="website">
    <meta property="og:locale" content="es_AR">

    <link rel="icon" type="image/x-icon" href="@AppSettings.GetValue("Diseno:FavIconUrl")" asp-append-version="true">

    <link rel="stylesheet" href="~/lib/bootstrap/css/bootstrap.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/font/bootstrap-icons.min.css" asp-append-version="true" />

    <partial name="_Theme" />

    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
    <script src="~/js/site.js" asp-append-version="true"></script>
</head>

@await Html.PartialAsync("_MensajeTempData")

<body>
    <aside class="sidebar offcanvas-md offcanvas-start bg-body-tertiary d-flex flex-column vh-100 border-end" id="sidebarAdmin">
        <div class="d-md-none p-3 text-end">
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas" data-bs-target="#sidebarAdmin"></button>
        </div>

        <div class="p-4 d-flex align-items-center border-bottom border-light-subtle mb-3">
            <div class="rounded-3 p-2 me-3 d-flex align-items-center justify-content-center shadow-sm">
                <img src="@AppSettings.GetValue("Diseno:LogoUrl")" alt="Logo" width="30" height="30" asp-append-version="true" />
            </div>
            <div class="overflow-hidden">
                <h6 class="fw-bold mb-0 text-uppercase tracking-wider">@AppSettings.GetValue("Diseno:NombreDelSitio")</h6>
                <small class="text-secondary text-uppercase fw-semibold" style="font-size: 0.65rem; letter-spacing: 1px;">Admin Panel</small>
            </div>
        </div>

        <nav class="nav flex-column flex-nowrap overflow-y-auto overflow-x-hidden w-100 px-3" style="flex: 1;">

            <div class="nav-item">
                <a class="nav-link py-2 px-3 my-1 fw-medium rounded-2 link-body-emphasis d-flex align-items-center bg-body-secondary-hover @ActiveClass("Home", "IndexAdmin")" asp-controller="Home" asp-action="IndexAdmin">
                    <i class="bi bi-house-door me-2 text-primary"></i>
                    <span>Inicio</span>
                </a>
            </div>

            <div class="nav-item">
                <hr class="my-2 border-1" />
            </div>

            <small class="text-uppercase text-muted fw-bold mt-3 mb-2 ps-3" style="font-size: 0.7rem;">Gestión de Tienda</small>

            @foreach (var link in gestionTiendaLinks)
            {
                <div class="nav-item">
                    <a class="nav-link py-2 px-3 my-1 fw-medium rounded-2 link-body-emphasis d-flex justify-content-between align-items-center @ActiveClass(link.Controller, link.Action, null)"
                       asp-controller="@link.Controller" asp-action="@link.Action">
                        <span><i class="bi @link.Icon me-2 text-primary"></i> @link.Text</span>
                    </a>
                </div>
            }

            <div class="nav-item">
                <hr class="my-2 border-1" />
            </div>

            <small class="text-uppercase text-muted fw-bold mt-3 mb-2 ps-3" style="font-size: 0.7rem;">Operaciones</small>

            @foreach (var link in operacionesLinks)
            {
                <div class="nav-item">
                    <a class="nav-link py-2 px-3 my-1 fw-medium rounded-2 link-body-emphasis d-flex justify-content-between align-items-center @ActiveClass(link.Controller, link.Action, null)"
                       asp-controller="@link.Controller" asp-action="@link.Action">
                        <span><i class="bi @link.Icon me-2 text-primary"></i> @link.Text</span>
                    </a>
                </div>
            }

            <div class="nav-item">
                <hr class="my-2 border-1" />
            </div>

            <small class="text-uppercase text-muted fw-bold mt-3 mb-2 ps-3" style="font-size: 0.7rem;">Configuración</small>

            @foreach (var link in configLinks)
            {
                <div class="nav-item">
                    <a class="nav-link py-2 px-3 my-1 fw-medium rounded-2 link-body-emphasis d-flex justify-content-between align-items-center @ActiveClass(link.Controller, link.Action, link.GroupName)"
                       asp-controller="@link.Controller" asp-action="@link.Action" asp-route-groupName="@link.GroupName">
                        <span><i class="bi @link.Icon me-2 text-primary"></i> @link.Text</span>
                    </a>
                </div>
            }

            <div class="nav-item">
                <button id="btn-theme" class="btn btn-link nav-link text-body p-2 rounded-circle" title="Cambiar tema">
                    <i id="theme-icon" class="bi bi-sun-fill fs-5"></i> Claro/Oscuro
                </button>
            </div>

            <div class="nav-item">
                <a class="nav-link py-2 px-3 my-1 fw-medium rounded-2 link-body-emphasis  align-items-center" asp-controller="Home" asp-action="Index">
                    <span><i class="bi bi-house-door me-2 text-primary"></i> Volver al Sitio</span>
                </a>
            </div>

            <div class="nav-item">
                <button type="button" class="nav-link py-2 px-3 my-1 fw-medium rounded-2 link-body-emphasis align-items-center btn-logout" style="cursor:pointer; border:none; background:transparent; width:100%; text-align:left;">
                    <span><i class="bi bi-power me-2 text-primary"></i> Cerrar Sesión</span>
                </button>
            </div>

            <div class="nav-item">
                <button class="btn d-flex align-items-center gap-2 border-0 gap-2 py-2" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="bi bi-person-circle fs-4 text-primary"></i> @nombreUsuario
                </button>
            </div>
        </nav>
    </aside>

    <div class="main-wrapper">
        <header class="navbar navbar-expand bg-body border-bottom sticky-top p-0 d-md-none" style="height: 70px;">
            <div class="container-fluid px-4">
                <button class="btn d-md-none me-3" type="button" data-bs-toggle="offcanvas" data-bs-target="#sidebarAdmin">
                    <i class="bi bi-list fs-4"></i>
                </button>

                <div class="ms-auto d-flex align-items-center gap-2">
                    <button id="btn-theme" class="btn nav-link text-body px-2" title="Cambiar tema">
                        <i id="theme-icon" class="bi bi-sun fs-4"></i>
                    </button>

                    <div class="dropdown">
                        <button class="btn d-flex align-items-center gap-2 border-0 p-1 dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-person-circle fs-2 text-primary"></i>
                            <p class="mb-0 small fw-bold text-body-emphasis lh-1 me-2">@nombreUsuario</p>
                        </button>

                        <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-3 mt-2">
                            <li><h6 class="dropdown-header">Mi Cuenta</h6></li>
                            <li>
                                <a class="dropdown-item d-flex align-items-center gap-2 py-2" asp-controller="Home" asp-action="Index">
                                    <i class="bi bi-house-door text-secondary"></i> Volver al Sitio
                                </a>
                            </li>
                            <li><hr class="dropdown-divider opacity-50"></li>
                            <li>
                                <button type="button" class="dropdown-item d-flex align-items-center gap-2 py-2 text-danger btn-logout" style="cursor:pointer; border:none; background:transparent; width:100%; text-align:left;">
                                    <i class="bi bi-power"></i> Cerrar Sesión
                                </button>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </header>

<form id="logoutForm" asp-controller="Accounts" asp-action="Logout" method="post" class="d-none">
    @Html.AntiForgeryToken()
</form>

        <main class="container-fluid p-md-4">
            
            <div class="bg-body border rounded-3 p-md-4 min-vh-100">
                @RenderBody()
            </div>
        </main>
    </div>

    
</body>
</html>
<script src="~/lib/jquery/dist/jquery.min.js" asp-append-version="true"></script>
<script src="~/lib/bootstrap/js/bootstrap.bundle.min.js" asp-append-version="true"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
<partial name="_ValidationScriptsPartial" />
@await RenderSectionAsync("Scripts", required: false)