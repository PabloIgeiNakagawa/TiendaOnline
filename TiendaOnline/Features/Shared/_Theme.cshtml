@{
    // 1. Fuentes
    var fontTitle = AppSettings.GetValue("Diseno:FuenteTitulo", "Inter");
    var fontBody = AppSettings.GetValue("Diseno:FuenteBody", "Inter");
    if (string.IsNullOrWhiteSpace(fontTitle)) fontTitle = "Inter";
    if (string.IsNullOrWhiteSpace(fontBody)) fontBody = "Inter";
    var fontUrl = $"https://fonts.googleapis.com/css2?family={fontTitle.Replace(" ", "+")}:wght@600;700&family={fontBody.Replace(" ", "+")}:wght@300;400;500&display=swap";

    // 2. Colores Base (Extraídos exactamente de tus AppSettings)
    var primary = AppSettings.GetValue("Diseno:ColorPrimary", "#0d6efd");

    // 3. Colores Modo Oscuro (Calculados al vuelo mediante la función)
    // El 'true' es para fondos (los oscurece), el 'false' es para textos/links (los aclara)
    var primaryDark = GenerateDarkColor(primary, false);
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="@fontUrl" rel="stylesheet">

<style>
    :root,
    [data-bs-theme="light"] {
        /* Tipografías */
        --bs-body-font-family: "@fontBody", system-ui, -apple-system, sans-serif;
        --bs-heading-font-family: "@fontTitle", system-ui, -apple-system, sans-serif;
    }

    h1, h2, h3, .h1, .h2, .h3 {
        font-family: "@fontTitle", system-ui, -apple-system, sans-serif;
    }

    [data-bs-theme="dark"] {
    }
</style>

@functions {
    // Convierte un HEX a "R, G, B" para las variables -rgb de Bootstrap
    public string HexToRgb(string hex)
    {
        try
        {
            if (string.IsNullOrEmpty(hex)) return "13, 110, 253";
            hex = hex.Replace("#", "");
            if (hex.Length != 6) return "13, 110, 253";

            int r = int.Parse(hex.Substring(0, 2), System.Globalization.NumberStyles.HexNumber);
            int g = int.Parse(hex.Substring(2, 2), System.Globalization.NumberStyles.HexNumber);
            int b = int.Parse(hex.Substring(4, 2), System.Globalization.NumberStyles.HexNumber);

            return $"{r}, {g}, {b}";
        }
        catch
        {
            return "13, 110, 253";
        }
    }

    // Función mágica: Calcula una paleta oscura basada en un color HEX claro
    public string GenerateDarkColor(string hex, bool isBackground)
    {
        if (string.IsNullOrEmpty(hex)) return hex;
        hex = hex.Replace("#", "");
        if (hex.Length != 6) return "#" + hex;

        try
        {
            int r = int.Parse(hex.Substring(0, 2), System.Globalization.NumberStyles.HexNumber);
            int g = int.Parse(hex.Substring(2, 2), System.Globalization.NumberStyles.HexNumber);
            int b = int.Parse(hex.Substring(4, 2), System.Globalization.NumberStyles.HexNumber);

            if (isBackground)
            {
                // Para fondos: Invierte el color y lo oscurece (evita blancos rotos brillantes en modo oscuro)
                // Usamos un factor de compresión para que no sea un negro absoluto #000000,
                // sino un tono oscuro agradable tipo #212529.
                r = Math.Clamp((int)((255 - r) * 0.85) + 15, 0, 255);
                g = Math.Clamp((int)((255 - g) * 0.85) + 15, 0, 255);
                b = Math.Clamp((int)((255 - b) * 0.85) + 15, 0, 255);
            }
            else
            {
                // Para textos/links: Aclara los colores para que resalten sobre fondos oscuros
                r = Math.Clamp((int)(r + (255 - r) * 0.7), 0, 255);
                g = Math.Clamp((int)(g + (255 - g) * 0.7), 0, 255);
                b = Math.Clamp((int)(b + (255 - b) * 0.7), 0, 255);
            }

            return $"#{r:X2}{g:X2}{b:X2}";
        }
        catch
        {
            return "#" + hex; // Si falla, devuelve el color original
        }
    }
}