@using System.Security.Claims
<header class="bg-body">
    <div class="container py-3">
        <div class="row align-items-center gy-3">

            <div class="col-6 col-lg-3 d-flex justify-content-start">
                <a class="d-flex align-items-center text-decoration-none" asp-controller="Home" asp-action="Index" title="Ir al inicio">
                    <img src="@AppSettings.GetValue("Diseno:LogoUrl")" alt="@AppSettings.GetValue("Diseno:NombreDelSitio") Logo" width="50" height="50" asp-append-version="true" loading="eager" class="img-fluid" />
                </a>
            </div>

            <div class="col-12 col-lg-6 order-3 order-lg-2">
                <form class="w-100" method="get" asp-controller="Productos" asp-action="Index">
                    <div class="input-group rounded-2 overflow-hidden border-0">
                        <input class="form-control border py-2"
                               type="search"
                               name="busqueda"
                               placeholder="Buscar procesadores, gráficas, memorias..."
                               aria-label="Buscar"
                               style="font-size: 0.95rem;">

                        <button class="btn btn-primary" type="submit">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                </form>
            </div>

            <div class="col-6 col-lg-3 order-2 order-lg-3 d-flex justify-content-end align-items-center gap-2">

                <a class="nav-link text-body position-relative px-2" asp-controller="Carritos" asp-action="Index">
                    <i class="bi bi-cart3 fs-4"></i>
                    @await Component.InvokeAsync("CarritoHeader")
                </a>

                <button id="btn-theme" class="btn nav-link text-body px-2" title="Cambiar tema">
                    <i id="theme-icon" class="bi bi-sun fs-4"></i>
                </button>

                <div class="dropdown">
                    <button class="btn nav-link px-2 dropdown-toggle d-flex align-items-center gap-1" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="bi bi-person fs-3"></i>
                        @if (User?.Identity?.IsAuthenticated == true)
                        {
                            <span class="d-none d-sm-inline small fw-medium">@User.FindFirstValue(ClaimTypes.Name)</span>
                        }
                    </button>

                    <ul class="dropdown-menu dropdown-menu-end rounded-3 p-2" style="min-width: 200px;">
                        @if (User?.Identity?.IsAuthenticated == true)
                        {
                            <li><h6 class="dropdown-header text-uppercase fw-bold small">Mi Cuenta</h6></li>

                            <li>
                                <a class="dropdown-item rounded-2 py-2" asp-controller="Usuarios" asp-action="PerfilUsuario" asp-route-id="@User?.FindFirstValue(ClaimTypes.NameIdentifier)">
                                    <i class="bi bi-person me-2"></i>Mi Perfil
                                </a>
                            </li>

                            @if (User?.IsInRole("Administrador") == true)
                            {
                                <li><hr class="dropdown-divider mx-2"></li>
                                <li><h6 class="dropdown-header text-uppercase fw-bold small text-primary">Gestión</h6></li>
                                <li>
                                    <a class="dropdown-item rounded-2 py-2 fw-semibold" asp-controller="Home" asp-action="IndexAdmin">
                                        <i class="bi bi-shield-lock me-2"></i>Panel Admin
                                    </a>
                                </li>
                            }
                            else if (User?.IsInRole("Repartidor") == true)
                            {
                                <li><hr class="dropdown-divider mx-2"></li>
                                <li>
                                    <a class="dropdown-item rounded-2 py-2" asp-controller="Admin" asp-action="Pedidos">
                                        <i class="bi bi-truck me-2"></i>Pedidos Asignados
                                    </a>
                                </li>
                            }
                            else
                            {
                                <li>
                                    <a class="dropdown-item rounded-2 py-2" asp-controller="Pedidos" asp-action="MisPedidos">
                                        <i class="bi bi-bag-check me-2"></i>Mis Pedidos
                                    </a>
                                </li>
                            }

                            <li><hr class="dropdown-divider mx-2"></li>
                            <li>
                                <button type="button" class="dropdown-item rounded-2 py-2 text-danger btn-logout" style="cursor:pointer; border:none; background:transparent; width:100%; text-align:left;">
                                    <i class="bi bi-box-arrow-right me-2"></i>Cerrar Sesión
                                </button>
                            </li>
                        }
                        else
                        {
                            <li><h6 class="dropdown-header text-uppercase fw-bold small">Bienvenido</h6></li>
                            <li>
                                <a class="dropdown-item rounded-2 py-2" asp-controller="Accounts" asp-action="Login">
                                    <i class="bi bi-box-arrow-in-right me-2"></i>Ingresar
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item rounded-2 py-2" asp-controller="Accounts" asp-action="Register">
                                    <i class="bi bi-person-plus me-2"></i>Registrarse
                                </a>
                            </li>
                        }
                    </ul>
                </div>

                <button class="btn btn-link text-body d-lg-none text-decoration-none p-2" type="button" data-bs-toggle="collapse" data-bs-target="#navegacionInferior">
                    <i class="bi bi-list fs-1"></i>
                </button>
            </div>
        </div>
    </div>

    <div class="border-top bg-body-tertiary">
        <div class="container">
            <div class="collapse navbar-collapse d-lg-flex justify-content-center" id="navegacionInferior">
                <ul class="navbar-nav flex-row gap-3 justify-content-center">
                    <li class="nav-item">
                        <a class="nav-link fw-semibold px-3 text-body-secondary" asp-controller="Home" asp-action="Index">Inicio</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link fw-semibold px-3 text-body-secondary" asp-controller="Productos" asp-action="Index">Productos</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link fw-semibold px-3 text-body-secondary" asp-controller="Soporte" asp-action="FAQ">FAQ</a>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</header>

<form id="logoutForm" asp-controller="Accounts" asp-action="Logout" method="post" class="d-none">
    @Html.AntiForgeryToken()
</form>