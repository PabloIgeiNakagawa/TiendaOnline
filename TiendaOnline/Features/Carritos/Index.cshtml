@using TiendaOnline.Application.Carritos
@model List<ItemCarrito>
@{
    ViewData["Title"] = "Carrito de Compras";
    bool usuarioEstaAutenticado = User.Identity != null && User.Identity.IsAuthenticated;
    decimal total = Model.Sum(i => i.Precio * i.Cantidad);
    var productosTotal = Model.Sum(i => i.Cantidad);
    var itemsSinStock = Model.Where(i => !i.HayStockSuficiente).ToList();
    var tieneStockInsuficiente = itemsSinStock.Any();
}


<div class="container py-4">
    <div class="mb-4 border-bottom pb-3">
        <h1 class="fs-3 fw-bold d-flex align-items-center text-primary gap-2">
            <i class="bi bi-cart3"></i>
            @ViewData["Title"]
            @if (Model != null && Model.Any())
            {
                <span class="bg-primary text-white small fw-semibold rounded-pill px-3 py-1 ms-2">@productosTotal</span>
            }
        </h1>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="rounded-3 shadow-sm p-5 text-center my-4">
            <i class="bi bi-cart-x fs-1 mb-4 opacity-50"></i>
            <h3 class="h4 fw-semibold mb-3">Tu carrito está vacío</h3>
            <p class="text-secondary mb-5">¡Parece que aún no has agregado productos a tu carrito de compras!</p>
            <a asp-controller="Productos" asp-action="Index"
               class="btn btn-primary fw-medium px-4 py-2 rounded-3 shadow-sm d-inline-flex align-items-center border-0">
                <i class="bi bi-cart-plus-fill fs-5 me-2"></i>
                <span>Comenzar compra</span>
            </a>
        </div>
    }
    else
    {
        @if (tieneStockInsuficiente)
        {
            <div class="alert alert-warning mb-4" role="alert">
                <div class="d-flex align-items-center">
                    <i class="bi bi-exclamation-triangle-fill fs-4 me-3"></i>
                    <div>
                        <strong>Algunos productos tienen stock limitado.</strong>
                        <p class="mb-0 small">Los productos marcados en amarillo o rojo tienen menos stock del solicitado. Ajusta las cantidades antes de continuar.</p>
                    </div>
                </div>
            </div>
        }

        <div class="row">
            <div class="col-lg-8">
                @foreach (var item in Model)
                {
                    <div class="card border shadow-sm mb-4 rounded-3 overflow-hidden">
                        <div class="d-flex flex-column flex-md-row p-3 p-md-4">

                            <div class="d-flex align-items-center justify-content-center bg-light mb-3 mb-md-0 me-md-4 flex-shrink-0 rounded-2 overflow-hidden mx-auto mx-md-0"
                                 style="width: 140px; height: 140px;">
                                @if (item.ImagenUrl != null)
                                {
                                    <a asp-controller="Productos" asp-action="Detalles" asp-route-id="@item.ProductoId">
                                        <img src="@item.ImagenUrl" alt="@item.Nombre" class="w-100 h-100 object-fit-cover" />
                                    </a>
                                }
                                else
                                {
                                    <i class="bi bi-box text-muted" style="font-size: 2rem;"></i>
                                }
                            </div>

                            <div class="flex-grow-1 d-flex flex-column">
                                <div class="text-center text-md-start">
                                    <a asp-controller="Productos" asp-action="Detalles" asp-route-id="@item.ProductoId" class="h5 fw-semibold mb-1 text-decoration-none">@item.Nombre</a>
                                    <div class="fs-5 fw-bold mb-2">@item.Precio.ToString("C0")</div>

                                    @if (item.SinStock)
                                    {
                                        <span class="badge bg-danger mb-2">
                                            <i class="bi bi-x-circle me-1"></i> Sin stock
                                        </span>
                                    }
                                    else if (!item.HayStockSuficiente)
                                    {
                                        <span class="badge bg-warning text-dark mb-2">
                                            <i class="bi bi-exclamation-triangle me-1"></i> Stock bajo: @item.StockDisponible disponibles
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success mb-2">
                                            <i class="bi bi-check-circle me-1"></i> @item.StockDisponible en stock
                                        </span>
                                    }

                                    <div class="small text-muted mb-3">
                                        Subtotal: <strong>@((item.Precio * item.Cantidad).ToString("C0"))</strong>
                                    </div>
                                </div>

                                <div class="d-flex flex-wrap align-items-center justify-content-center justify-content-md-start mt-auto gap-3">

                                    <form asp-action="ActualizarCantidad" method="post" class="d-flex align-items-center">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="productoId" value="@item.ProductoId" />

                                        <div class="d-flex align-items-center border border-2 rounded-2 overflow-hidden" style="width: fit-content;">
                                            <button type="button"
                                                    class="btn text-secondary d-flex align-items-center justify-content-center p-0 border-0 btn-disminuir"
                                                    data-producto-id="@item.ProductoId"
                                                    @(item.SinStock ? "disabled" : "")
                                                    style="width: 32px; height: 32px;">
                                                <i class="bi bi-dash"></i>
                                            </button>
                                            <input id="cantidad-@item.ProductoId"
                                                   type="number" name="cantidad"
                                                   value="@item.Cantidad" min="1" max="@(item.SinStock ? 0 : item.StockDisponible)"
                                                   class="form-control border-0 text-center fw-semibold p-1 shadow-none"
                                                   style="width: 50px;" />
                                            <button type="button"
                                                    class="btn text-secondary d-flex align-items-center justify-content-center p-0 border-0 btn-aumentar"
                                                    data-producto-id="@item.ProductoId"
                                                    @(item.SinStock || !item.HayStockSuficiente ? "disabled" : "")
                                                    style="width: 32px; height: 32px;">
                                                <i class="bi bi-plus"></i>
                                            </button>
                                        </div>

                                        <button type="submit" class="btn btn-primary rounded-2 fw-semibold ms-2">
                                            <i class="bi bi-arrow-repeat"></i>
                                            <span class="d-none d-sm-inline"> Actualizar</span>
                                        </button>
                                    </form>

                                    <form asp-action="EliminarItem" method="post"
                                          class="position-absolute top-0 end-0 p-3" style="z-index: 10;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.ProductoId" />
                                        <button type="submit"
                                                class="btn btn-link text-danger p-0 border-0 shadow-none btn-eliminar"
                                                title="Eliminar">
                                            <i class="bi bi-trash3-fill fs-5"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                <div class="text-center mb-4">
                    <a asp-controller="Productos" asp-action="Index" class="btn btn-outline-info fw-semibold rounded-2 d-inline-flex align-items-center gap-2 mt-3">
                        <i class="bi bi-arrow-left"></i>
                        Continuar comprando
                    </a>
                </div>
                <div class="text-center mb-4">
                    <form asp-action="Vaciar" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-cart-x-fill"></i>
                            Vaciar carrito
                        </button>
                    </form>

                </div>
            </div>

            <div class="col-lg-4">
                <div class="bg-body-tertiary rounded-3 shadow-sm p-4 border">
                    <h3 class="h5 fw-semibold mb-4 pb-3 border-bottom">Resumen del pedido</h3>

                    @foreach (var item in Model)
                    {
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <div class="pe-2">
                                <p class="mb-0 fw-semibold small text-truncate @(item.SinStock ? "text-danger" : (!item.HayStockSuficiente ? "text-warning" : ""))" style="max-width: 180px;">
                                    @item.Nombre
                                    @if (item.SinStock)
                                    {
                                        <i class="bi bi-x-circle text-danger ms-1" title="Sin stock"></i>
                                    }
                                    else if (!item.HayStockSuficiente)
                                    {
                                        <i class="bi bi-exclamation-triangle text-warning ms-1" title="Stock bajo"></i>
                                    }
                                </p>
                                <small class="text-muted">Cantidad: @item.Cantidad</small>
                            </div>
                            <span class="fw-medium small">
                                @((item.Precio * item.Cantidad).ToString("C0"))
                            </span>
                        </div>
                    }

                    <div class="d-flex justify-content-between mt-4 pt-3 border-top fw-bold fs-5 text-primary">
                        <span>Total</span>
                        <span>@total.ToString("C0")</span>
                    </div>

                    @if (usuarioEstaAutenticado)
                    {
                        @if (tieneStockInsuficiente)
                        {
                            <button type="button" class="btn btn-secondary fw-bold w-100 mt-4 d-flex align-items-center justify-content-center gap-2 rounded-2" disabled>
                                <i class="bi bi-cart-check"></i> Ajustar stock antes de continuar
                            </button>
                            <p class="text-center small text-muted mt-2 mb-0">Corrige las cantidades marcadas en amarillo/rojo</p>
                        }
                        else
                        {
                            <form asp-controller="Pedidos" asp-action="CheckOut" method="get">
                                <button type="submit" class="btn btn-success fw-bold w-100 mt-4 d-flex align-items-center justify-content-center gap-2 rounded-2">
                                    <i class="bi bi-cart-check"></i> Ir al CheckOut
                                </button>
                            </form>
                        }
                    }
                    else
                    {
                        <a class="btn btn-success fw-bold w-100 mt-4 d-flex align-items-center justify-content-center gap-2 rounded-2 disabled" href="#" tabindex="-1" aria-disabled="true">
                            <i class="bi bi-cart-check"></i> Ir al Checkout
                        </a>

                        <div class="mt-3 text-center">
                            <p class="mb-1 small text-muted">Para finalizar la compra debes iniciar sesión</p>
                            <div class="d-flex justify-content-center gap-2">
                                <a asp-controller="Accounts" asp-action="Login" class="fw-bold text-decoration-none">
                                    Ingresar
                                </a>
                                <span class="text-muted">|</span>
                                <a asp-controller="Accounts" asp-action="Register" class="fw-bold text-decoration-none">
                                    Crear cuenta
                                </a>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script src="~/js/Features/Carritos/Index.js" asp-append-version="true"></script>
}
